{{ define "profile/activity.tmpl" }}
{{ template "layouts/app_header" . }}
      <div style="margin-bottom: 3rem;">
        <h1 style="font-size: 2rem;" data-translate="activity_title">Riwayat Aktivitas</h1>
        <p style="color: var(--text-secondary); margin-top: 0.25rem;" data-translate="activity_desc">Pantau log login, aktivitas sistem, dan akses perangkat Anda di sini.</p>
      </div>

      <div class="card" style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2.5rem; max-width: 900px; box-shadow: 0 8px 32px rgba(0,0,0,0.25);">
        <div style="overflow-x: auto;">
          <table>
            <thead>
              <tr>
                <th data-translate="col_time">Waktu</th>
                <th data-translate="col_activity">Aktivitas</th>
                <th data-translate="col_device">Perangkat</th>
                <th data-translate="col_ip">IP Address</th>
              </tr>
            </thead>
            <tbody>
              {{ if not .Logs }}
                <tr>
                  <td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 2rem;" data-translate="no_activity">
                    Belum ada riwayat aktivitas yang tercatat.
                  </td>
                </tr>
              {{ else }}
                {{ range .Logs }}
                  <tr>
                    <td class="date-format" data-date="{{ .CreatedAt }}">
                      {{ .CreatedAt }}
                    </td>
                    <td style="font-weight: 600; color: var(--text-primary);">
                      {{ .Activity }}
                    </td>
                    <td>
                      {{ if eq .Device "Mobile" }}
                        <i class="fa-solid fa-mobile-screen-button" style="color: var(--accent-secondary); margin-right: 0.25rem;"></i>
                      {{ else if eq .Device "Tablet" }}
                        <i class="fa-solid fa-tablet-screen-button" style="color: var(--info); margin-right: 0.25rem;"></i>
                      {{ else }}
                        <i class="fa-solid fa-desktop" style="color: var(--accent-primary); margin-right: 0.25rem;"></i>
                      {{ end }}
                      {{ .Device }}
                    </td>
                    <td style="font-family: var(--font-mono); font-size: 0.85rem;">
                      {{ .IP }}
                    </td>
                  </tr>
                {{ end }}
              {{ end }}
            </tbody>
          </table>
        </div>
      </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
          } catch (e) {}
        }
      });
    });
  </script>
{{ template "layouts/app_footer" . }}
{{ end }}
