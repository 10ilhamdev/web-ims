{{ define "profile/password.tmpl" }}
{{ template "layouts/app_header" . }}
      <div style="margin-bottom: 3rem;">
        <h1 style="font-size: 2rem;" data-translate="password_title">Perbarui Password</h1>
        <p style="color: var(--text-secondary); margin-top: 0.25rem;" data-translate="password_desc">Jaga keamanan akun Anda dengan mengganti kata sandi secara berkala.</p>
      </div>

      {{ if .Success }}
        <div style="background: rgba(16, 185, 129, 0.15); border: 1px solid #10b981; color: #34d399; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; max-width: 650px;">
          <i class="fa-solid fa-circle-check" style="margin-right: 0.5rem;"></i> {{ .Success }}
        </div>
      {{ end }}

      {{ if .Error }}
        <div style="background: rgba(239, 68, 68, 0.15); border: 1px solid #ef4444; color: #f87171; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; max-width: 650px;">
          <i class="fa-solid fa-circle-xmark" style="margin-right: 0.5rem;"></i> {{ .Error }}
        </div>
      {{ end }}

      <div class="card" style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 2.5rem; max-width: 650px; box-shadow: 0 8px 32px rgba(0,0,0,0.25);">
        <form action="/profile/password" method="POST">
          <div class="form-group" style="margin-bottom: 1.25rem;">
            <label class="form-label" data-translate="current_password">Kata Sandi Saat Ini</label>
            <input type="password" name="current_password" class="form-control" required placeholder="Masukkan kata sandi lama" style="padding: 0.75rem 1rem;" data-translate="current_password_placeholder">
          </div>
          <div class="form-group" style="margin-bottom: 2rem;">
            <label class="form-label" data-translate="new_password">Kata Sandi Baru</label>
            <input type="password" name="new_password" class="form-control" required placeholder="Masukkan kata sandi baru" style="padding: 0.75rem 1rem;" data-translate="new_password_placeholder">
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.85rem; background: linear-gradient(135deg, var(--accent-secondary) 0%, #10b981 100%);">
            <span data-translate="btn_update_password">Perbarui Password</span>
          </button>
        </form>
      </div>
{{ template "layouts/app_footer" . }}
{{ end }}
