{{ define "admin/users_detail.tmpl" }}
{{ template "layouts/app_header" . }}
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;">User Details</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;">View platform user profile information.</p>
        </div>
        <a href="/admin/users" class="btn btn-secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-arrow-left"></i> Back to Users List
        </a>
      </div>

      <div style="max-width: 700px; margin: 0 auto;">
        <!-- Card -->
        <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary); padding: 3rem; border-radius: 20px; position: relative;">
          
          <div style="display: flex; gap: 2rem; align-items: center; margin-bottom: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 2rem;">
            <!-- Avatar Initials -->
            <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%); color: white; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700; text-transform: uppercase; box-shadow: 0 0 20px var(--accent-glow);">
              {{ slice .TargetUser.Name 0 2 }}
            </div>
            <div>
              <h2 style="font-size: 1.75rem; margin: 0; color: var(--text-primary);">{{ .TargetUser.Name }}</h2>
              <span class="badge badge-{{ if eq .TargetUser.Role "admin" }}completed{{ else }}in_progress{{ end }}" style="font-size: 0.85rem; margin-top: 0.5rem; text-transform: uppercase;">
                {{ .TargetUser.Role }}
              </span>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem;">
            <div>
              <div style="font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">Email Address</div>
              <div style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary); word-break: break-all;">{{ .TargetUser.Email }}</div>
            </div>

            <div>
              <div style="font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">System Role</div>
              <div style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary); text-transform: capitalize;">{{ .TargetUser.Role }}</div>
            </div>

            <div>
              <div style="font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">Created Account Date</div>
              <div class="date-format" data-date="{{ .TargetUser.CreatedAt }}" style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary);">{{ .TargetUser.CreatedAt }}</div>
            </div>

            <div>
              <div style="font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.35rem;">Last Updated Date</div>
              <div class="date-format" data-date="{{ .TargetUser.UpdatedAt }}" style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary);">{{ .TargetUser.UpdatedAt }}</div>
            </div>
          </div>

          <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-color); padding-top: 2rem;">
            <a href="/admin/users/{{ .TargetUser.ID }}/edit" class="btn btn-primary" style="text-decoration: none; padding: 0.75rem 2rem; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600;">
              <i class="fa-solid fa-user-gear"></i> Edit User
            </a>
          </div>
        </div>
      </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' });
          } catch (e) {}
        }
      });
    });
  </script>
{{ template "layouts/app_footer" . }}
{{ end }}
