{{ define "admin/users.tmpl" }}
{{ template "layouts/app_header" . }}
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;" data-translate="users_title">User Management</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;" data-translate="users_desc">Manage platform administrators and clients here.</p>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.9rem;">
          <i class="fa-solid fa-users" style="color: var(--accent-primary); margin-right: 0.5rem;"></i> <span data-translate="users_directory">User Directory</span>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; align-items: start;">
        
        <!-- Add User Form -->
        <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary); padding: 2rem;">
          <h3 style="font-size: 1.25rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-user-plus" style="margin-right: 0.5rem; color: var(--accent-primary);"></i> <span data-translate="users_add_new">Add New User</span></h3>
          <form action="/admin/users" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
              <label class="form-label" data-translate="full_name">Full Name</label>
              <input type="text" name="name" class="form-control" required placeholder="e.g. John Doe">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
              <label class="form-label" data-translate="email_address">Email Address</label>
              <input type="email" name="email" class="form-control" required placeholder="e.g. john@example.com">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
              <label class="form-label" data-translate="password_label">Password</label>
              <input type="password" name="password" class="form-control" required placeholder="Min 6 characters">
            </div>
            <div class="form-group" style="margin-bottom: 1.5rem;">
              <label class="form-label" data-translate="users_role">System Role</label>
              <select name="role" class="form-control">
                <option value="client" data-translate="users_role_client">Client</option>
                <option value="admin" data-translate="users_role_admin">Administrator</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
              <i class="fa-solid fa-plus"></i> <span data-translate="users_create_btn">Create Account</span>
            </button>
          </form>
        </div>

        <!-- Users Table -->
        <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary); padding: 2rem;">
          <h3 style="font-size: 1.25rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-users" style="margin-right: 0.5rem; color: var(--accent-primary);"></i> <span data-translate="users_list">Active Users List</span></h3>
          
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th data-translate="full_name">User Details</th>
                  <th data-translate="col_role">Role</th>
                  <th data-translate="col_placed_date">Created At</th>
                  <th data-translate="col_actions">Action</th>
                </tr>
              </thead>
              <tbody>
                {{ range .Users }}
                  <tr>
                    <td>
                      <div style="font-weight: 600;">{{ .Name }}</div>
                      <div style="font-size: 0.8rem; color: var(--text-secondary);">{{ .Email }}</div>
                    </td>
                    <td>
                      <span class="badge badge-{{ if eq .Role "admin" }}completed{{ else }}in_progress{{ end }}" style="font-size: 0.7rem;">
                        {{ .Role }}
                      </span>
                    </td>
                    <td class="date-format" data-date="{{ .CreatedAt }}">{{ .CreatedAt }}</td>
                    <td>
                      {{ if ne .Email "admin@ims.com" }}
                        <form action="/admin/users/{{ .ID }}/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this user?');">
                          <button type="submit" class="btn btn-danger btn-sm" style="padding: 0.35rem 0.6rem;"><i class="fa-solid fa-trash"></i></button>
                        </form>
                      {{ else }}
                        <span style="font-size: 0.8rem; color: var(--text-muted); font-style: italic;">Protected</span>
                      {{ end }}
                    </td>
                  </tr>
                {{ end }}
              </tbody>
            </table>
          </div>
        </div>

      </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
          } catch (e) {}
        }
      });
    });
  </script>
{{ template "layouts/app_footer" . }}
{{ end }}
