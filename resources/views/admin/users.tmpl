{{ define "admin/users.tmpl" }}
{{ template "layouts/app_header" . }}
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;" data-translate="users_title">User Management</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;" data-translate="users_desc">Manage platform administrators and clients here.</p>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.9rem;">
          <i class="fa-solid fa-users" style="color: var(--accent-primary); margin-right: 0.5rem;"></i> <span data-translate="users_directory">User Directory</span>
        </div>
      </div>

      <!-- Users Table Card -->
      <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary); padding: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
          <h3 style="font-size: 1.25rem; margin: 0;"><i class="fa-solid fa-users" style="margin-right: 0.5rem; color: var(--accent-primary);"></i> <span data-translate="users_list">Active Users List</span></h3>
          <a href="/admin/users/create" class="btn btn-primary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 500;">
            <i class="fa-solid fa-user-plus"></i> <span data-translate="users_add_new">Add New User</span>
          </a>
        </div>
        
        <!-- Tab Links -->
        <div class="tab-container" style="display: flex; gap: 0.5rem; border-bottom: 1px solid var(--border-color); margin-bottom: 1.5rem;">
          <button class="tab-btn active" id="tab-clients-btn" onclick="switchUserTab('clients')" style="background: none; border: none; color: var(--accent-primary); border-bottom: 2px solid var(--accent-primary); padding: 0.75rem 1.25rem; font-weight: 600; cursor: pointer; font-family: inherit; font-size: 0.92rem; outline: none; transition: all 0.3s;">
            Customers (Clients)
          </button>
          <button class="tab-btn" id="tab-admins-btn" onclick="switchUserTab('admins')" style="background: none; border: none; color: var(--text-secondary); border-bottom: 2px solid transparent; padding: 0.75rem 1.25rem; font-weight: 600; cursor: pointer; font-family: inherit; font-size: 0.92rem; outline: none; transition: all 0.3s;">
            Administrators
          </button>
        </div>

        <!-- Clients Tab Content -->
        <div id="clients-tab" class="tab-content" style="display: block;">
          <div class="table-responsive">
            <table id="clientsTable" class="display" style="width:100%;">
              <thead>
                <tr>
                  <th data-translate="full_name">User Details</th>
                  <th data-translate="email_address">Email</th>
                  <th data-translate="col_placed_date">Created At</th>
                  <th data-translate="col_actions" style="width: 220px;">Action</th>
                </tr>
              </thead>
              <tbody>
                {{ range .Users }}
                  {{ if eq .Role "client" }}
                    <tr>
                      <td>
                        <div style="font-weight: 600;">{{ .Name }}</div>
                        <div style="font-size: 0.75rem; color: var(--text-secondary); font-weight: 500; text-transform: uppercase;">Client</div>
                      </td>
                      <td style="font-family: var(--font-mono); font-size: 0.88rem;">{{ .Email }}</td>
                      <td class="date-format" data-date="{{ .CreatedAt }}">{{ .CreatedAt }}</td>
                      <td>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                          <a href="/admin/users/{{ .ID }}" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.78rem;">
                            <i class="fa-solid fa-eye"></i> Detail
                          </a>
                          <a href="/admin/users/{{ .ID }}/edit" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.78rem;">
                            <i class="fa-solid fa-edit"></i> Edit
                          </a>
                          <form action="/admin/users/{{ .ID }}/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this customer?');" style="display: inline-block;">
                            <button type="submit" class="btn btn-danger btn-sm" style="padding: 0.35rem 0.6rem; display: inline-flex; align-items: center; font-size: 0.78rem;"><i class="fa-solid fa-trash"></i></button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  {{ end }}
                {{ end }}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Admins Tab Content -->
        <div id="admins-tab" class="tab-content" style="display: none;">
          <div class="table-responsive">
            <table id="adminsTable" class="display" style="width:100%;">
              <thead>
                <tr>
                  <th data-translate="full_name">User Details</th>
                  <th data-translate="email_address">Email</th>
                  <th data-translate="col_placed_date">Created At</th>
                  <th data-translate="col_actions" style="width: 220px;">Action</th>
                </tr>
              </thead>
              <tbody>
                {{ range .Users }}
                  {{ if eq .Role "admin" }}
                    <tr>
                      <td>
                        <div style="font-weight: 600;">{{ .Name }}</div>
                        <div style="font-size: 0.75rem; color: var(--accent-secondary); font-weight: 500; text-transform: uppercase;">Admin</div>
                      </td>
                      <td style="font-family: var(--font-mono); font-size: 0.88rem;">{{ .Email }}</td>
                      <td class="date-format" data-date="{{ .CreatedAt }}">{{ .CreatedAt }}</td>
                      <td>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                          <a href="/admin/users/{{ .ID }}" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.78rem;">
                            <i class="fa-solid fa-eye"></i> Detail
                          </a>
                          <a href="/admin/users/{{ .ID }}/edit" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.78rem;">
                            <i class="fa-solid fa-edit"></i> Edit
                          </a>
                          {{ if ne .Email "admin@ims.com" }}
                            <form action="/admin/users/{{ .ID }}/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this administrator?');" style="display: inline-block;">
                              <button type="submit" class="btn btn-danger btn-sm" style="padding: 0.35rem 0.6rem; display: inline-flex; align-items: center; font-size: 0.78rem;"><i class="fa-solid fa-trash"></i></button>
                            </form>
                          {{ else }}
                            <span style="font-size: 0.8rem; color: var(--text-muted); font-style: italic; padding-left: 0.5rem;">Protected</span>
                          {{ end }}
                        </div>
                      </td>
                    </tr>
                  {{ end }}
                {{ end }}
              </tbody>
            </table>
          </div>
        </div>

      </div>

  <script src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js"></script>
  <script>
    $(document).ready(function() {
      const currentLang = localStorage.getItem('lang') || 'en';
      const langConfig = currentLang === 'en' ? {
        search: "Search:",
        lengthMenu: "Show _MENU_ entries per page",
        info: "Showing _START_ to _END_ of _TOTAL_ entries",
        paginate: {
          first: "First",
          last: "Last",
          next: "Next",
          previous: "Previous"
        }
      } : {
        search: "Cari:",
        lengthMenu: "Tampilkan _MENU_ data per halaman",
        info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ data",
        paginate: {
          first: "Pertama",
          last: "Terakhir",
          next: "Selanjutnya",
          previous: "Sebelumnya"
        }
      };

      $('#clientsTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        ordering: true,
        language: langConfig,
        drawCallback: function() {
          if (typeof applyAdminTranslations === 'function') {
            applyAdminTranslations(localStorage.getItem('lang') || 'en');
          }
        }
      });

      $('#adminsTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        ordering: true,
        language: langConfig,
        drawCallback: function() {
          if (typeof applyAdminTranslations === 'function') {
            applyAdminTranslations(localStorage.getItem('lang') || 'en');
          }
        }
      });

      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
          } catch (e) {}
        }
      });
    });

    function switchUserTab(tab) {
      const clientsTab = document.getElementById('clients-tab');
      const adminsTab = document.getElementById('admins-tab');
      const clientsBtn = document.getElementById('tab-clients-btn');
      const adminsBtn = document.getElementById('tab-admins-btn');

      if (tab === 'clients') {
        clientsTab.style.display = 'block';
        adminsTab.style.display = 'none';
        clientsBtn.style.color = 'var(--accent-primary)';
        clientsBtn.style.borderBottomColor = 'var(--accent-primary)';
        adminsBtn.style.color = 'var(--text-secondary)';
        adminsBtn.style.borderBottomColor = 'transparent';
      } else {
        clientsTab.style.display = 'none';
        adminsTab.style.display = 'block';
        clientsBtn.style.color = 'var(--text-secondary)';
        clientsBtn.style.borderBottomColor = 'transparent';
        adminsBtn.style.color = 'var(--accent-primary)';
        adminsBtn.style.borderBottomColor = 'var(--accent-primary)';
      }
    }
  </script>
{{ template "layouts/app_footer" . }}
{{ end }}
