{{ define "admin/dashboard.tmpl" }}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | IMS Control Panel</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body style="background-image: none; background-color: var(--bg-primary);">

  <div class="admin-layout">
    
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="logo">
        <div class="logo-icon">I</div>
        <span>IMS Admin</span>
      </div>
      
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          {{ if .User }}
            {{ printf "%.1s" .User.Name }}
          {{ else }}
            A
          {{ end }}
        </div>
        <div>
          <div style="font-weight: 600; font-size: 0.95rem;">{{ .User.Name }}</div>
          <div style="color: var(--accent-secondary); font-size: 0.8rem; font-weight: 500; text-transform: uppercase;">Administrator</div>
        </div>
      </div>
      
      <ul class="sidebar-menu">
        <li class="active">
          <a href="/admin"><i class="fa-solid fa-gauge"></i> Dashboard</a>
        </li>
        <li>
          <a href="/"><i class="fa-solid fa-globe"></i> Main Website</a>
        </li>
        <li>
          <a href="/products"><i class="fa-solid fa-list-check"></i> Pricing Packages</a>
        </li>
        <li style="margin-top: 4rem;">
          <a href="/logout" class="btn btn-danger btn-sm" style="color: #fff; justify-content: center; gap: 0.5rem;">
            <i class="fa-solid fa-sign-out"></i> Logout
          </a>
        </li>
      </ul>
    </aside>

    <!-- Main Admin Content -->
    <main class="admin-content">
      
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;">Overview & Management</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;">Welcome back, administrator. Manage sales operations here.</p>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.9rem;">
          <i class="fa-solid fa-calendar" style="color: var(--accent-primary); margin-right: 0.5rem;"></i> IMS Operations System
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;">Total Orders</div>
            <div class="stat-val">{{ .TotalOrders }}</div>
          </div>
          <div class="stat-icon"><i class="fa-solid fa-box"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;">Active Projects</div>
            <div class="stat-val">{{ .ActiveOrders }}</div>
          </div>
          <div class="stat-icon" style="color: var(--info);"><i class="fa-solid fa-spinner"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;">Total Revenue</div>
            <div class="stat-val" style="font-size: 1.5rem; margin-top: 0.8rem; color: var(--success);">
              Rp <span class="price-format" data-price="{{ .TotalRevenue }}">{{ .TotalRevenue }}</span>
            </div>
          </div>
          <div class="stat-icon" style="color: var(--success);"><i class="fa-solid fa-wallet"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;">Registered Clients</div>
            <div class="stat-val">{{ .TotalClients }}</div>
          </div>
          <div class="stat-icon" style="color: var(--accent-secondary);"><i class="fa-solid fa-users"></i></div>
        </div>
      </div>

      <!-- Orders Panel -->
      <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary);">
        <h3 style="font-size: 1.25rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-list" style="margin-right: 0.5rem; color: var(--accent-primary);"></i> Client Orders List</h3>
        
        <div class="table-responsive">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Client Name</th>
                <th>Package Name</th>
                <th>Price</th>
                <th>Status</th>
                <th>Update Status</th>
                <th>Placed Date</th>
              </tr>
            </thead>
            <tbody>
              {{ range .Orders }}
                <tr>
                  <td style="font-family: var(--font-mono); font-weight: 600; color: var(--accent-primary);">#IMS-{{ .ID }}</td>
                  <td>
                    <div style="font-weight: 600;">{{ .User.Name }}</div>
                    <div style="font-size: 0.8rem; color: var(--text-secondary);">{{ .User.Email }}</div>
                  </td>
                  <td style="font-weight: 600;">{{ .Product.Name }}</td>
                  <td style="font-family: var(--font-mono); font-weight: 600;">
                    Rp <span class="price-format" data-price="{{ .Price }}">{{ .Price }}</span>
                  </td>
                  <td>
                    <span class="badge badge-{{ .Status }}">{{ .Status }}</span>
                  </td>
                  <td>
                    <form action="/admin/orders/{{ .ID }}/status" method="POST" style="display: flex; gap: 0.5rem; align-items: center;">
                      <select name="status" class="form-control" style="width: auto; padding: 0.35rem 0.75rem; font-size: 0.85rem; background: rgba(0,0,0,0.2);">
                        <option value="pending" {{ if eq .Status "pending" }}selected{{ end }}>Pending</option>
                        <option value="in_progress" {{ if eq .Status "in_progress" }}selected{{ end }}>In Progress</option>
                        <option value="completed" {{ if eq .Status "completed" }}selected{{ end }}>Completed</option>
                        <option value="cancelled" {{ if eq .Status "cancelled" }}selected{{ end }}>Cancelled</option>
                      </select>
                      <button type="submit" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem;"><i class="fa-solid fa-save"></i></button>
                    </form>
                  </td>
                  <td class="date-format" data-date="{{ .CreatedAt }}">{{ .CreatedAt }}</td>
                </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Format prices
      document.querySelectorAll('.price-format').forEach(el => {
        const val = parseFloat(el.getAttribute('data-price'));
        if (!isNaN(val)) {
          el.textContent = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(val);
        }
      });

      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
          } catch (e) {}
        }
      });
    });
  </script>
</body>
</html>
{{ end }}
