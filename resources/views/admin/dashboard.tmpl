{{ define "admin/dashboard.tmpl" }}
{{ template "layouts/app_header" . }}
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;" data-translate="dash_title">Overview & Management</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;" data-translate="dash_desc">Welcome back, administrator. Manage sales operations here.</p>
        </div>
        <div style="color: var(--text-secondary); font-size: 0.9rem;">
          <i class="fa-solid fa-calendar" style="color: var(--accent-primary); margin-right: 0.5rem;"></i> IMS Operations System
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;" data-translate="dash_total_orders">Total Orders</div>
            <div class="stat-val">{{ .TotalOrders }}</div>
          </div>
          <div class="stat-icon"><i class="fa-solid fa-box"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;" data-translate="dash_active_projects">Active Projects</div>
            <div class="stat-val">{{ .ActiveOrders }}</div>
          </div>
          <div class="stat-icon" style="color: var(--info);"><i class="fa-solid fa-spinner"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;" data-translate="dash_total_revenue">Total Revenue</div>
            <div class="stat-val" style="font-size: 1.5rem; margin-top: 0.8rem; color: var(--success);">
              <span data-translate-currency>Rp</span> <span class="price-format" data-price="{{ .TotalRevenue }}">{{ .TotalRevenue }}</span>
            </div>
          </div>
          <div class="stat-icon" style="color: var(--success);"><i class="fa-solid fa-wallet"></i></div>
        </div>

        <div class="stat-card">
          <div>
            <div style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; font-weight: 600;" data-translate="dash_registered_clients">Registered Clients</div>
            <div class="stat-val">{{ .TotalClients }}</div>
          </div>
          <div class="stat-icon" style="color: var(--accent-primary);"><i class="fa-solid fa-users"></i></div>
        </div>
      </div>

      <!-- Recent Orders Section -->
      <div class="card" style="margin-top: 2rem; border-color: var(--border-color);">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
          <h3 style="font-size: 1.1rem; font-family: var(--font-mono); margin: 0;" data-translate="dash_recent_orders">Recent Orders</h3>
        </div>
        <div style="overflow-x: auto;">
          <table class="admin-table">
            <thead>
              <tr>
                <th style="width: 80px;">ID</th>
                <th data-translate="dash_col_client">Client</th>
                <th data-translate="dash_col_package">Package</th>
                <th data-translate="dash_col_price">Price</th>
                <th data-translate="dash_col_status">Status</th>
                <th data-translate="dash_col_action">Action</th>
                <th data-translate="dash_col_date">Date</th>
              </tr>
            </thead>
            <tbody>
              {{ range .RecentOrders }}
                <tr>
                  <td style="font-family: var(--font-mono); font-weight: 600; color: var(--accent-primary);">#IMS-{{ .ID }}</td>
                  <td>
                    <div style="font-weight: 600;">{{ .User.Name }}</div>
                    <div style="font-size: 0.78rem; color: var(--text-secondary);">{{ .User.Email }}</div>
                  </td>
                  <td style="font-weight: 600;">{{ .Product.Name }}</td>
                  <td style="font-family: var(--font-mono); font-weight: 600;">
                    <span data-translate-currency>Rp</span> <span class="price-format" data-price="{{ .Price }}">{{ .Price }}</span>
                  </td>
                  <td>
                    <span class="badge badge-{{ .Status }}">{{ .Status }}</span>
                  </td>
                  <td>
                    <form action="/admin/orders/{{ .ID }}/status" method="POST" style="display: flex; gap: 0.5rem; align-items: center;">
                      <select name="status" class="form-control" style="width: auto; padding: 0.35rem 0.75rem; font-size: 0.85rem; background: rgba(0,0,0,0.2);">
                        <option value="pending" {{ if eq .Status "pending" }}selected{{ end }}>Pending</option>
                        <option value="in_progress" {{ if eq .Status "in_progress" }}selected{{ end }}>In Progress</option>
                        <option value="completed" {{ if eq .Status "completed" }}selected{{ end }}>Completed</option>
                        <option value="cancelled" {{ if eq .Status "cancelled" }}selected{{ end }}>Cancelled</option>
                      </select>
                      <button type="submit" class="btn btn-secondary btn-sm" style="padding: 0.35rem 0.6rem;"><i class="fa-solid fa-save"></i></button>
                    </form>
                  </td>
                  <td class="date-format" data-date="{{ .CreatedAt }}">{{ .CreatedAt }}</td>
                </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
      </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      function updatePrices() {
        const lang = localStorage.getItem('lang') || 'en';
        document.querySelectorAll('.price-format').forEach(el => {
          const val = parseFloat(el.getAttribute('data-price'));
          if (!isNaN(val)) {
            if (lang === 'en') {
              let usd = val / 15000;
              if (val === 500000) usd = 35;
              if (val === 4500000) usd = 300;
              el.textContent = new Intl.NumberFormat('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(usd);
            } else {
              el.textContent = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(val);
            }
          }
        });
        document.querySelectorAll('[data-translate-currency]').forEach(el => {
          el.textContent = lang === 'en' ? '$' : 'Rp';
        });
      }
      updatePrices();

      // Format dates
      document.querySelectorAll('.date-format').forEach(el => {
        const dateStr = el.getAttribute('data-date');
        if (dateStr) {
          try {
            const d = new Date(dateStr);
            el.textContent = d.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });
          } catch (e) {}
        }
      });
    });
  </script>
{{ template "layouts/app_footer" . }}
{{ end }}
