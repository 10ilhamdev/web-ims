{{ define "admin/chat.tmpl" }}
{{ template "layouts/app_header" . }}

<style>
  .chat-wrapper {
    display: flex;
    height: calc(100vh - 200px);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    margin-top: 1rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .chat-sidebar {
    width: 320px;
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.01);
  }

  .chat-sidebar-header {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    font-weight: 600;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .chat-sessions-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
  }

  .chat-session-item {
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }

  .chat-session-item:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--border-color);
  }

  .chat-session-item.active {
    background: rgba(37, 99, 235, 0.1);
    border-color: var(--accent-primary);
  }

  .session-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .session-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .session-time {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .session-last-msg {
    font-size: 0.85rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.1);
  }

  .chat-main-header {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .chat-main-header-info h4 {
    margin: 0;
    font-weight: 600;
    font-size: 1.05rem;
  }

  .chat-main-header-info p {
    margin: 0.15rem 0 0 0;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .chat-messages-container {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .message-bubble {
    max-width: 70%;
    padding: 0.85rem 1.1rem;
    border-radius: 14px;
    font-size: 0.95rem;
    line-height: 1.4;
    word-break: break-word;
  }

  .message-bubble.user {
    align-self: flex-start;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border-bottom-left-radius: 4px;
    border: 1px solid var(--border-color);
  }

  .message-bubble.admin {
    align-self: flex-end;
    background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
    color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
  }

  .chat-input-container {
    padding: 1.25rem;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
  }

  .chat-input-form {
    display: flex;
    gap: 0.75rem;
  }

  .chat-input-form input {
    flex: 1;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
    color: var(--text-primary);
    outline: none;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .chat-input-form input:focus {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.15);
  }

  .chat-placeholder {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    text-align: center;
    padding: 2rem;
  }

  .chat-placeholder i {
    font-size: 3rem;
    color: var(--accent-primary);
    opacity: 0.5;
    margin-bottom: 1rem;
  }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
  <div>
    <h1 style="font-size: 2rem;">Support Chat Hub</h1>
    <p style="color: var(--text-secondary); margin-top: 0.25rem;">Reply to client and guest inquiries here in real time.</p>
  </div>
  <div style="color: var(--text-secondary); font-size: 0.9rem;">
    <i class="fa-solid fa-circle" style="color: var(--success); font-size: 0.6rem; margin-right: 0.5rem; animation: pulse 1.5s infinite;"></i> Support Engine Active
  </div>
</div>

<div class="chat-wrapper">
  <!-- Sidebar -->
  <aside class="chat-sidebar">
    <div class="chat-sidebar-header">
      <i class="fa-solid fa-message"></i>
      <span>Active Discussions</span>
    </div>
    <div class="chat-sessions-list" id="sessions-list">
      <!-- Loaded dynamically -->
    </div>
  </aside>

  <!-- Main Chat -->
  <main class="chat-main" id="chat-main">
    <div class="chat-placeholder" id="chat-placeholder">
      <i class="fa-solid fa-comments"></i>
      <h3>No Conversation Selected</h3>
      <p>Click on any discussion in the list to view history and start typing a response.</p>
    </div>
    
    <div id="chat-active-area" style="display: none; height: 100%; flex-direction: column;">
      <div class="chat-main-header">
        <div class="chat-main-header-info">
          <h4 id="active-user-name">Loading...</h4>
          <p id="active-user-email">Loading...</p>
        </div>
      </div>
      <div class="chat-messages-container" id="messages-container">
        <!-- Loaded dynamically -->
      </div>
      <div class="chat-input-container">
        <form class="chat-input-form" onsubmit="sendReply(event)">
          <input type="text" id="reply-input" placeholder="Type your response here..." autocomplete="off">
          <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
            <span>Send</span> <i class="fa-solid fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>
  </main>
</div>

