<script>
  // Let's rewrite the JS functions with correct session properties.
  let currentToken = null;

  async function loadSessions() {
    try {
      const res = await fetch('/api/admin/chat/sessions');
      const sessions = await res.json();
      
      const container = document.getElementById('sessions-list');
      if (!sessions || sessions.length === 0) {
        container.innerHTML = `<div style="text-align:center; padding:2rem; color:var(--text-secondary); font-size:0.9rem;">No active chats</div>`;
        return;
      }

      let html = '';
      sessions.forEach(s => {
        const isActive = activeChatId === s.ID ? 'active' : '';
        // Format time
        let timeStr = '';
        if (s.last_time) {
          const d = new Date(s.last_time);
          timeStr = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
        html += `
          <div class="chat-session-item ${isActive}" onclick="selectSession(${s.ID}, '${s.token}', '${escapeHTML(s.name)}', '${escapeHTML(s.email)}')">
            <div class="session-meta">
              <span class="session-name">${escapeHTML(s.name)}</span>
              <span class="session-time">${timeStr}</span>
            </div>
            <div class="session-last-msg">${escapeHTML(s.last_message || 'No messages')}</div>
          </div>
        `;
      });
      container.innerHTML = html;
    } catch (err) {
      console.error("Error loading sessions:", err);
    }
  }

  function selectSession(id, token, name, email) {
    activeChatId = id;
    currentToken = token;
    
    document.getElementById('chat-placeholder').style.display = 'none';
    document.getElementById('chat-active-area').style.display = 'flex';
    
    document.getElementById('active-user-name').textContent = name;
    document.getElementById('active-user-email').textContent = email;

    // Reset input
    document.getElementById('reply-input').value = '';

    loadMessages();
    
    if (pollingInterval) clearInterval(pollingInterval);
    pollingInterval = setInterval(loadMessages, 3000);
  }

  async function loadMessages() {
    if (!currentToken) return;
    try {
      const res = await fetch(`/api/chat/support/messages?token=${currentToken}`);
      const messages = await res.json();
      
      const container = document.getElementById('messages-container');
      const wasScrolledToBottom = container.scrollHeight - container.clientHeight <= container.scrollTop + 50;

      let html = '';
      messages.forEach(m => {
        const senderClass = m.sender_type === 'admin' ? 'admin' : 'user';
        html += `
          <div class="message-bubble ${senderClass}">
            ${escapeHTML(m.message)}
          </div>
        `;
      });
      container.innerHTML = html;

      // Auto scroll to bottom
      if (wasScrolledToBottom || container.innerHTML.includes('Loading messages...')) {
        container.scrollTop = container.scrollHeight;
      }
    } catch (err) {
      console.error("Error loading messages:", err);
    }
  }

  async function sendReply(e) {
    e.preventDefault();
    const input = document.getElementById('reply-input');
    const message = input.value.trim();
    if (!message || !activeChatId) return;

    input.value = '';
    
    try {
      const form = new FormData();
      form.append('chat_id', activeChatId);
      form.append('message', message);

      const res = await fetch('/api/admin/chat/reply', {
        method: 'POST',
        body: form
      });
      
      if (res.ok) {
        loadMessages();
        loadSessions();
      }
    } catch (err) {
      console.error("Error sending reply:", err);
    }
  }

  function escapeHTML(str) {
    if (!str) return '';
    return str.replace(/[&<>'"]/g, 
      tag => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;'
      }[tag] || tag)
    );
  }

  // Load list on startup
  document.addEventListener('DOMContentLoaded', () => {
    loadSessions();
    setInterval(loadSessions, 6000);
  });
</script>

