{{ define "admin/roles.tmpl" }}
{{ template "layouts/app_header" . }}
      <!-- Top header -->
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <div>
          <h1 style="font-size: 2rem;" data-translate="menu_roles">Role & Database Schema Manager</h1>
          <p style="color: var(--text-secondary); margin-top: 0.25rem;">Define custom user roles and manage their physical database schemas like phpMyAdmin.</p>
        </div>
        <button class="btn btn-primary" onclick="openCreateModal()">
          <i class="fa-solid fa-plus-circle"></i> <span data-translate="btn_add_role">Create Custom Role</span>
        </button>
      </div>

      <!-- Roles DataTable -->
      <div class="card" style="border-color: var(--border-color); background: var(--bg-secondary); padding: 2rem;">
        <table id="rolesTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th style="width: 30px;"></th>
              <th data-translate="col_role_name">Role Name</th>
              <th data-translate="col_role_label">Display Label</th>
              <th data-translate="col_db_table">Associated DB Table</th>
              <th data-translate="col_relation_name">Relation Struct</th>
              <th data-translate="col_is_system">System Role</th>
              <th data-translate="col_is_registerable">Registerable</th>
              <th style="width: 150px;" data-translate="col_actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{ range .Roles }}
              <tr data-table="{{ .TableName }}">
                <td style="text-align: center; cursor: pointer; vertical-align: middle;" class="details-control">
                  <i class="fa-solid fa-chevron-right" style="transition: transform 0.2s; color: var(--accent-primary);"></i>
                </td>
                <td style="font-weight: 600; color: var(--text-primary); vertical-align: middle;">{{ .Name }}</td>
                <td style="font-weight: 600; color: var(--text-secondary); vertical-align: middle;">{{ .Label }}</td>
                <td style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent-secondary); vertical-align: middle;">{{ .TableName }}</td>
                <td style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--info); vertical-align: middle;">{{ .RelationName }}</td>
                <td style="vertical-align: middle;">
                  <span class="badge badge-{{ if .IsSystem }}completed{{ else }}pending{{ end }}" style="font-size: 0.75rem;">
                    {{ if .IsSystem }}Yes{{ else }}No{{ end }}
                  </span>
                </td>
                <td style="vertical-align: middle;">
                  <span class="badge badge-{{ if .IsRegisterable }}completed{{ else }}pending{{ end }}" style="font-size: 0.75rem;">
                    {{ if .IsRegisterable }}Yes{{ else }}No{{ end }}
                  </span>
                </td>
                <td style="vertical-align: middle;">
                  <div style="display: flex; gap: 0.5rem;">
                    <button class="btn btn-secondary btn-sm" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; gap: 0.4rem;" 
                      onclick="onEditClick(this)"
                      data-id="{{ .ID }}"
                      data-name="{{ .Name }}"
                      data-label="{{ .Label }}"
                      data-table="{{ .TableName }}"
                      data-relation="{{ .RelationName }}"
                      data-is-system="{{ .IsSystem }}"
                      data-is-registerable="{{ .IsRegisterable }}"
                      data-badge-color="{{ .BadgeColor }}"
                      data-description="{{ .Description }}"
                      data-dashboard-route="{{ .DashboardRoute }}"
                      data-dashboard-view="{{ .DashboardView }}">
                      <i class="fa-solid fa-edit"></i> Edit
                    </button>
                    {{ if not .IsSystem }}
                      <form action="/admin/roles/{{ .ID }}/delete" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus role ini?');" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </form>
                    {{ else }}
                      <span style="font-size: 0.8rem; color: var(--text-muted); font-style: italic; display: flex; align-items: center; padding-left: 0.5rem;">Protected</span>
                    {{ end }}
                  </div>
                </td>
              </tr>
            {{ end }}
          </tbody>
        </table>
      </div>

  <!-- Create Role Modal -->
  <div class="role-modal" id="createRoleModal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
    <div class="role-modal-content" style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
        <h3 style="font-size: 1.35rem; color: var(--text-primary);"><i class="fa-solid fa-folder-plus" style="color: var(--accent-primary); margin-right: 0.5rem;"></i> Create Custom Role</h3>
        <button style="background:none; border:none; color:var(--text-secondary); font-size: 1.5rem; cursor:pointer;" onclick="closeCreateModal()">&times;</button>
      </div>
      
      <form action="/admin/roles" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">Role Name (key)</label>
            <input type="text" name="name" class="form-control" placeholder="e.g. manager" required pattern="[a-z0-9_]+">
          </div>
          <div class="form-group">
            <label class="form-label">Display Label</label>
            <input type="text" name="label" class="form-control" placeholder="e.g. Project Manager" required>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">DB Table Name</label>
            <input type="text" name="table_name" class="form-control" placeholder="e.g. managers" required pattern="[a-z0-9_]+">
          </div>
          <div class="form-group">
            <label class="form-label">Relation Struct Name</label>
            <input type="text" name="relation_name" class="form-control" placeholder="e.g. Manager" required pattern="[A-Za-z0-9_]+">
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">System Protected Role?</label>
            <select name="is_system" class="form-control">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Allow Registration?</label>
            <select name="is_registerable" class="form-control">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">Badge Color Theme</label>
            <select name="badge_color" class="form-control">
              <option value="primary">Primary (Blue)</option>
              <option value="success">Success (Green)</option>
              <option value="danger">Danger (Red)</option>
              <option value="warning">Warning (Yellow)</option>
              <option value="info">Info (Teal)</option>
              <option value="secondary">Secondary (Gray)</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Dashboard Route</label>
            <input type="text" name="dashboard_route" class="form-control" placeholder="e.g. /manager/dashboard">
          </div>
        </div>

        <div class="form-group" style="margin-bottom: 1.25rem;">
          <label class="form-label">Dashboard View</label>
          <input type="text" name="dashboard_view" class="form-control" placeholder="e.g. manager/dashboard">
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Describe role responsibilities..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem;">
          <i class="fa-solid fa-save"></i> Save Role
        </button>
      </form>
    </div>
  </div>

  <!-- Edit Role Modal -->
  <div class="role-modal" id="editRoleModal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
    <div class="role-modal-content" style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
        <h3 style="font-size: 1.35rem; color: var(--text-primary);"><i class="fa-solid fa-pen-to-square" style="color: var(--accent-secondary); margin-right: 0.5rem;"></i> Edit Role</h3>
        <button style="background:none; border:none; color:var(--text-secondary); font-size: 1.5rem; cursor:pointer;" onclick="closeEditModal()">&times;</button>
      </div>
      
      <form id="editRoleForm" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">Role Name (Readonly)</label>
            <input type="text" id="editRoleName" name="name" class="form-control" readonly style="background: rgba(255,255,255,0.02); cursor: not-allowed;">
          </div>
          <div class="form-group">
            <label class="form-label">Display Label</label>
            <input type="text" id="editRoleLabel" name="label" class="form-control" required>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">DB Table Name</label>
            <input type="text" id="editRoleTableName" name="table_name" class="form-control" required pattern="[a-z0-9_]+">
          </div>
          <div class="form-group">
            <label class="form-label">Relation Struct Name</label>
            <input type="text" id="editRoleRelationName" name="relation_name" class="form-control" required pattern="[A-Za-z0-9_]+">
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">System Protected Role?</label>
            <select id="editRoleIsSystem" name="is_system" class="form-control">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Allow Registration?</label>
            <select id="editRoleIsRegisterable" name="is_registerable" class="form-control">
              <option value="0">No</option>
              <option value="1">Yes</option>
            </select>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label class="form-label">Badge Color Theme</label>
            <select id="editRoleBadgeColor" name="badge_color" class="form-control">
              <option value="primary">Primary (Blue)</option>
              <option value="success">Success (Green)</option>
              <option value="danger">Danger (Red)</option>
              <option value="warning">Warning (Yellow)</option>
              <option value="info">Info (Teal)</option>
              <option value="secondary">Secondary (Gray)</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Dashboard Route</label>
            <input type="text" id="editRoleDashboardRoute" name="dashboard_route" class="form-control">
          </div>
        </div>

        <div class="form-group" style="margin-bottom: 1.25rem;">
          <label class="form-label">Dashboard View</label>
          <input type="text" id="editRoleDashboardView" name="dashboard_view" class="form-control">
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
          <label class="form-label">Description</label>
          <textarea id="editRoleDescription" name="description" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.8rem;">
          <i class="fa-solid fa-check"></i> Save Changes
        </button>
      </form>
    </div>
  </div>

{{ template "layouts/app_footer" . }}

  <!-- Scripts -->
  <script src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js"></script>
  <script>
    $(document).ready(function() {
      const currentLang = localStorage.getItem('lang') || 'en';
      const langConfig = currentLang === 'en' ? {
        search: "Search:",
        lengthMenu: "Show _MENU_ entries per page",
        info: "Showing _START_ to _END_ of _TOTAL_ roles",
        paginate: {
          first: "First",
          last: "Last",
          next: "Next",
          previous: "Previous"
        }
      } : {
        search: "Cari:",
        lengthMenu: "Tampilkan _MENU_ data per halaman",
        info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ data",
        paginate: {
          first: "Pertama",
          last: "Terakhir",
          next: "Selanjutnya",
          previous: "Sebelumnya"
        }
      };

      const table = $('#rolesTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        ordering: true,
        language: langConfig,
        drawCallback: function() {
          if (typeof applyAdminTranslations === 'function') {
            applyAdminTranslations(localStorage.getItem('lang') || 'en');
          }
        }
      });

      function getHumanLabel(name) {
        if (name === 'id') return 'Id';
        return name.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
      }

      // Add event listener for opening and closing details row
      $('#rolesTable tbody').on('click', 'td.details-control', function () {
          var tr = $(this).closest('tr');
          var icon = $(this).find('i');
          var tableName = tr.attr('data-table');
          var row = table.row(tr);

          if (row.child.isShown()) {
              // Close detail row
              row.child.hide();
              tr.removeClass('shown');
              icon.removeClass('fa-chevron-down').addClass('fa-chevron-right');
          } else {
              // Open detail row
              icon.removeClass('fa-chevron-right').addClass('fa-chevron-down');
              row.child('<div style="padding: 1.5rem; color: var(--text-secondary);"><i class="fa-solid fa-spinner fa-spin"></i> Loading schema fields...</div>').show();
              tr.addClass('shown');

              // Fetch columns dynamically from the database
              fetch(`/admin/db-columns/${tableName}`)
                .then(res => res.json())
                .then(cols => {
                  if (cols.error) {
                    row.child(`<div style="padding: 1.5rem; color: var(--accent-primary);"><i class="fa-solid fa-exclamation-triangle"></i> Error: ${cols.error}</div>`).show();
                  } else {
                    let html = `<div style="padding: 1.5rem; background: var(--bg-primary); border-radius: 12px; margin: 0.75rem 0; border: 1px solid var(--border-color);">`;
                    html += `<h4 style="margin-top: 0; margin-bottom: 1.25rem; color: var(--text-primary); font-size: 1rem; font-weight: 600;"><i class="fa-solid fa-table"></i> Struktur Tabel: <span style="font-family: monospace; color: var(--accent-secondary); font-size: 0.95rem;">${tableName}</span></h4>`;
                    html += `<div class="table-responsive">`;
                    html += `<table class="schema-detail-table" style="width: 100%; border-collapse: collapse; font-size: 0.85rem; text-align: left;">`;
                    html += `<thead>`;
                    html += `  <tr style="border-bottom: 2px solid var(--border-color);">`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Column</th>`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Type</th>`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Label</th>`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Attributes</th>`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Foreign Key</th>`;
                    html += `    <th style="padding: 0.75rem 0.5rem; color: var(--text-secondary); font-weight: 600;">Options</th>`;
                    html += `  </tr>`;
                    html += `</thead>`;
                    html += `<tbody>`;

                    cols.forEach(col => {
                      // Attributes
                      let attrs = [];
                      if (col.col_key === 'PRI') attrs.push('<span class="badge badge-completed" style="background: rgba(245,158,11,0.15); color: #f59e0b; font-size: 0.72rem; padding: 0.2rem 0.4rem; margin-right: 0.25rem;">Primary</span>');
                      if (col.extra && col.extra.includes('auto_increment')) attrs.push('<span class="badge badge-completed" style="background: rgba(245,158,11,0.15); color: #f59e0b; font-size: 0.72rem; padding: 0.2rem 0.4rem; margin-right: 0.25rem;">Auto Inc</span>');
                      if (col.full_type && col.full_type.includes('unsigned')) attrs.push('<span class="badge badge-in_progress" style="background: rgba(139,92,246,0.15); color: #8b5cf6; font-size: 0.72rem; padding: 0.2rem 0.4rem; margin-right: 0.25rem;">Unsigned</span>');
                      if (col.col_key === 'UNI') attrs.push('<span class="badge badge-in_progress" style="background: rgba(59,130,246,0.15); color: #3b82f6; font-size: 0.72rem; padding: 0.2rem 0.4rem; margin-right: 0.25rem;">Unique</span>');
                      if (col.is_nullable === 'YES') attrs.push('<span class="badge badge-pending" style="background: rgba(16,185,129,0.15); color: #10b981; font-size: 0.72rem; padding: 0.2rem 0.4rem; margin-right: 0.25rem;">Nullable</span>');
                      
                      let attrsHtml = attrs.length > 0 ? attrs.join(' ') : '—';

                      // Foreign Key
                      let fkHtml = '—';
                      if (col.ref_table && col.ref_column) {
                        fkHtml = `<span style="color: var(--text-primary); font-family: monospace;">${col.ref_table}.${col.ref_column}</span><br><span style="font-size: 0.75rem; color: var(--text-secondary);">on delete: cascade on update: restrict</span>`;
                      }

                      // Options
                      let optionsHtml = '—';
                      if (col.full_type && col.full_type.startsWith('enum(')) {
                        optionsHtml = col.full_type.substring(5, col.full_type.length - 1).replace(/'/g, '').split(',').join(', ');
                      }

                      // Clean Type
                      let cleanType = col.full_type ? col.full_type.split(' ')[0] : col.type;

                      html += `<tr style="border-bottom: 1px solid var(--border-color);">`;
                      html += `  <td style="padding: 0.75rem 0.5rem; font-weight: 600; color: var(--text-primary);">${col.name}</td>`;
                      html += `  <td style="padding: 0.75rem 0.5rem;"><span style="font-family: monospace; background: var(--bg-secondary); padding: 0.2rem 0.4rem; border-radius: 4px; border: 1px solid var(--border-color);">${cleanType}</span></td>`;
                      html += `  <td style="padding: 0.75rem 0.5rem; color: var(--text-primary);">${getHumanLabel(col.name)}</td>`;
                      html += `  <td style="padding: 0.75rem 0.5rem;">${attrsHtml}</td>`;
                      html += `  <td style="padding: 0.75rem 0.5rem; line-height: 1.3;">${fkHtml}</td>`;
                      html += `  <td style="padding: 0.75rem 0.5rem; color: var(--text-secondary);">${optionsHtml}</td>`;
                      html += `</tr>`;
                    });

                    html += `</tbody></table></div></div>`;
                    row.child(html).show();
                  }
                })
                .catch(err => {
                  row.child(`<div style="padding: 1.5rem; color: var(--accent-primary);"><i class="fa-solid fa-exclamation-triangle"></i> Error loading schema</div>`).show();
                });
          }
      });
    });

    function openCreateModal() {
      document.getElementById('createRoleModal').style.display = 'flex';
    }
    function closeCreateModal() {
      document.getElementById('createRoleModal').style.display = 'none';
    }

    function onEditClick(btn) {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');
      const label = btn.getAttribute('data-label');
      const tableName = btn.getAttribute('data-table');
      const relation = btn.getAttribute('data-relation');
      const isSystem = btn.getAttribute('data-is-system') === 'true' ? '1' : '0';
      const isRegisterable = btn.getAttribute('data-is-registerable') === 'true' ? '1' : '0';
      const badgeColor = btn.getAttribute('data-badge-color');
      const description = btn.getAttribute('data-description');
      const route = btn.getAttribute('data-dashboard-route');
      const view = btn.getAttribute('data-dashboard-view');

      document.getElementById('editRoleForm').action = '/admin/roles/' + id + '/edit';
      document.getElementById('editRoleName').value = name;
      document.getElementById('editRoleLabel').value = label;
      document.getElementById('editRoleTableName').value = tableName;
      document.getElementById('editRoleRelationName').value = relation;
      document.getElementById('editRoleIsSystem').value = isSystem;
      document.getElementById('editRoleIsRegisterable').value = isRegisterable;
      document.getElementById('editRoleBadgeColor').value = badgeColor || 'primary';
      document.getElementById('editRoleDescription').value = description || '';
      document.getElementById('editRoleDashboardRoute').value = route || '';
      document.getElementById('editRoleDashboardView').value = view || '';

      document.getElementById('editRoleModal').style.display = 'flex';
    }

    function closeEditModal() {
      document.getElementById('editRoleModal').style.display = 'none';
    }

    window.onclick = function(event) {
      const createModal = document.getElementById('createRoleModal');
      const editModal = document.getElementById('editRoleModal');
      if (event.target == createModal) {
        closeCreateModal();
      }
      if (event.target == editModal) {
        closeEditModal();
      }
    }
  </script>
{{ end }}
