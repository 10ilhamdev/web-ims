{{ define "home.tmpl" }}
{{ template "layouts/header.tmpl" . }}

<section class="container hero animated" style="position: relative; overflow: visible;">
  <!-- HD Futuristic Dotted Wave Background -->
  <svg class="bg-dot-wave" viewBox="0 0 1440 800" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M-100,200 C300,50 600,450 1000,150 C1200,50 1500,250 1600,100" stroke="var(--accent-secondary)"
      stroke-width="2.5" stroke-dasharray="2, 16" stroke-linecap="round" opacity="0.25" />
    <path d="M-100,240 C300,90 600,490 1000,190 C1200,90 1500,290 1600,140" stroke="var(--accent-primary)"
      stroke-width="2.5" stroke-dasharray="2, 16" stroke-linecap="round" opacity="0.18" />
    <path d="M-100,160 C300,10 600,410 1000,110 C1200,10 1500,210 1600,60" stroke="#8b5cf6" stroke-width="2"
      stroke-dasharray="2, 16" stroke-linecap="round" opacity="0.15" />
    <path d="M400,650 C700,480 900,750 1100,580 C1200,480 1400,600 1600,500" stroke="var(--accent-secondary)"
      stroke-width="3" stroke-dasharray="2, 20" stroke-linecap="round" opacity="0.2" />
    <path d="M400,690 C700,520 900,790 1100,620 C1200,520 1400,640 1600,540" stroke="#8b5cf6" stroke-width="2.5"
      stroke-dasharray="2, 20" stroke-linecap="round" opacity="0.15" />
  </svg>


  <div class="hero-content">
    <p class="hero-slogan" data-translate="hero_slogan">Turning Ideas Into Digital Solutions</p>
    <h1 class="hero-title reveal reveal-up">
      <span data-translate="hero_title_1">Tingkatkan Bisnis Anda Dengan</span><br>
      <span class="gradient-text" data-translate="hero_title_2">Pengembangan Website Premium</span>
    </h1>
    <p class="hero-desc reveal reveal-up" data-translate="hero_desc">
      IMS (Innovation Massive Solutions) merancang dan membangun aplikasi web berkinerja tinggi yang disesuaikan untuk
      bisnis Anda.
      Aman, responsif, dan dibuat menggunakan teknologi modern seperti Laravel, React, Vue, Go, dan Node.js.
    </p>
    <div class="hero-buttons reveal reveal-up">
      <a href="/products" class="btn btn-primary"><i class="fa-solid fa-rocket"></i> <span
          data-translate="btn_view_packages">Lihat Paket Kami</span></a>
      <a href="/services" class="btn btn-secondary" data-translate="btn_explore_services">Jelajahi Layanan</a>
    </div>
  </div>

  <div class="logo-bg-watermark logo-watermark-home reveal reveal-right">
    <svg viewBox="0 0 500 500" fill="none">
      <defs>
        <!-- Clean sharp gradients -->
        <linearGradient id="blueGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#3b82f6" />
          <stop offset="100%" stop-color="#00add8" />
        </linearGradient>
        <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#fbbf24" />
          <stop offset="100%" stop-color="#d97706" />
        </linearGradient>
        <!-- Sharp dot matrix pattern inside shapes -->
        <pattern id="logoDots" x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.3" fill="rgba(255, 255, 255, 0.75)" />
        </pattern>
      </defs>
      
      <!-- Crown on Top - Clean sharp outline and semi-transparent fill -->
      <path d="M 170 140 L 150 80 L 210 100 L 250 30 L 290 100 L 350 80 L 330 140 Z" fill="url(#goldGrad)" stroke="rgba(251, 191, 36, 0.95)" stroke-width="2.5" stroke-linejoin="round" />
      <path d="M 170 140 L 150 80 L 210 100 L 250 30 L 290 100 L 350 80 L 330 140 Z" fill="url(#logoDots)" />
      
      <!-- Main Blue Ring (the C-like shape) - Sharp gradient and inner dot matrix -->
      <path d="M 150 180 A 130 130 0 1 1 220 370 L 220 315 A 75 75 0 1 0 180 215 Z" fill="url(#blueGrad)" stroke="rgba(59, 130, 246, 0.95)" stroke-width="2.5" stroke-linejoin="round" />
      <path d="M 150 180 A 130 130 0 1 1 220 370 L 220 315 A 75 75 0 1 0 180 215 Z" fill="url(#logoDots)" />
      
      <!-- Digital Pixel Blocks at the bottom -->
      <rect x="130" y="320" width="30" height="30" rx="2" fill="rgba(0, 173, 216, 0.75)" stroke="rgba(0, 173, 216, 0.95)" stroke-width="2" />
      <rect x="175" y="340" width="25" height="25" rx="2" fill="rgba(59, 130, 246, 0.75)" stroke="rgba(59, 130, 246, 0.95)" stroke-width="2" />
      <rect x="150" y="365" width="28" height="28" rx="2" fill="rgba(29, 78, 216, 0.75)" stroke="rgba(29, 78, 216, 0.95)" stroke-width="2" />

      <!-- IMS Text in Center - Crisp, modern, no glow -->
      <text x="260" y="275" font-family="'Space Grotesk', sans-serif" font-weight="800" font-size="52" fill="#ffffff" opacity="0.9" text-anchor="middle" letter-spacing="2">IMS</text>
    </svg>
  </div>
</section>

<!-- Technologies / Stack Banner -->
<section class="container reveal reveal-up" style="margin-top: 8rem; margin-bottom: 7rem; text-align: center;">
  <p style="color: var(--text-muted); font-size: 0.92rem; text-transform: uppercase; letter-spacing: 0.18em; margin-bottom: 1.25rem;"
    data-translate="stack_banner_text">Teknologi yang Kami Kuasai</p>
  <div class="tech-slider-container">
    <div class="tech-slider-track">
      <!-- Original Set -->
      <span title="Laravel" onmouseover="this.style.color='#ff2d20'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-laravel"></i></span>
      <span title="React" onmouseover="this.style.color='#61dbfb'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-react"></i></span>
      <span title="Vue.js" onmouseover="this.style.color='#41b883'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-vuejs"></i></span>
      <span title="Node.js" onmouseover="this.style.color='#68a063'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-node-js"></i></span>
      <span title="PHP" onmouseover="this.style.color='#777bb4'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-php"></i></span>
      <span title="WordPress" onmouseover="this.style.color='#21759b'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-wordpress"></i></span>
      <span title="Python" onmouseover="this.style.color='#3776ab'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-python"></i></span>
      <span title="Golang" style="font-family: var(--font-mono); font-size: 2.1rem; font-weight: bold;"
        onmouseover="this.style.color='#00add8'" onmouseout="this.style.color=''">Go</span>

      <!-- Duplicate Set for continuous loop -->
      <span title="Laravel" onmouseover="this.style.color='#ff2d20'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-laravel"></i></span>
      <span title="React" onmouseover="this.style.color='#61dbfb'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-react"></i></span>
      <span title="Vue.js" onmouseover="this.style.color='#41b883'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-vuejs"></i></span>
      <span title="Node.js" onmouseover="this.style.color='#68a063'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-node-js"></i></span>
      <span title="PHP" onmouseover="this.style.color='#777bb4'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-php"></i></span>
      <span title="WordPress" onmouseover="this.style.color='#21759b'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-wordpress"></i></span>
      <span title="Python" onmouseover="this.style.color='#3776ab'" onmouseout="this.style.color=''"><i
          class="fa-brands fa-python"></i></span>
      <span title="Golang" style="font-family: var(--font-mono); font-size: 2.1rem; font-weight: bold;"
        onmouseover="this.style.color='#00add8'" onmouseout="this.style.color=''">Go</span>
    </div>
  </div>
</section>

<!-- Services / Features Summary -->
<section class="container">
  <div class="section-header reveal reveal-up">
    <h2 data-translate="why_partner_title">Mengapa Bermitra dengan IMS?</h2>
    <p data-translate="why_partner_desc">Kami membangun sistem web yang unggul dalam kinerja, keamanan, dan pengalaman
      pengguna.</p>
  </div>

  <div class="features-grid">
    <div class="feature-card reveal reveal-left">
      <div class="feature-icon"><i class="fa-solid fa-code"></i></div>
      <h3 class="feature-title" data-translate="feature_clean_code">Kode Bersih Modern</h3>
      <p class="feature-desc" data-translate="feature_clean_code_desc">Memanfaatkan arsitektur perangkat lunak yang kuat
        dengan React, Node.js, dan Golang untuk memastikan pemeliharaan basis kode yang mudah.</p>
    </div>
    <div class="feature-card reveal reveal-up">
      <div class="feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <h3 class="feature-title" data-translate="feature_security">Keamanan Skala Enterprise</h3>
      <p class="feature-desc" data-translate="feature_security_desc">Kami menerapkan enkripsi tingkat tinggi,
        pemeriksaan keamanan digital, dan mekanisme otentikasi yang aman di setiap proyek.</p>
    </div>
    <div class="feature-card reveal reveal-right">
      <div class="feature-icon"><i class="fa-solid fa-gauge-high"></i></div>
      <h3 class="feature-title" data-translate="feature_performance">Performa Tinggi</h3>
      <p class="feature-desc" data-translate="feature_performance_desc">Pemuatan halaman yang sangat cepat dengan
        optimasi sisi server, cache konten, dan sistem desain yang responsif.</p>
    </div>
  </div>
</section>

<!-- CTA section -->
<section class="container reveal reveal-up" style="margin-bottom: 6rem;">
  <div class="card web3-cta-card">
    <div
      style="position: absolute; top: -50px; left: -50px; width: 150px; height: 150px; background: var(--accent-primary); filter: blur(100px); opacity: 0.35;">
    </div>
    <h2 data-translate="cta_ready_title">Siap Meluncurkan Usaha Digital Anda?</h2>
    <p data-translate="cta_ready_desc">
      Pilih dari paket web yang sudah kami siapkan atau ajukan cetak biru portal kustom yang dirancang sesuai kebutuhan
      Anda.
    </p>
    <a href="/products" class="btn btn-primary btn-lg"><i class="fa-solid fa-shopping-cart"></i> <span
        data-translate="cta_btn_get_started">Mulai Sekarang</span></a>
  </div>
</section>

{{ template "layouts/footer.tmpl" . }}
{{ end }}