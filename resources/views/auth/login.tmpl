{{ define "auth/login.tmpl" }}
{{ template "layouts/header.tmpl" . }}

<section class="container">
  <div class="form-container animated">
    <div style="text-align: center; margin-bottom: 2rem;">
      <h2 style="font-size: 2rem; font-family: var(--font-mono); margin-bottom: 0.5rem;">Sign In</h2>
      <p style="color: var(--text-secondary);">Access your IMS account & dashboard</p>
    </div>

    {{ if .Error }}
      <div class="form-alert form-alert-danger">
        <i class="fa-solid fa-triangle-exclamation" style="margin-right: 0.5rem;"></i> {{ .Error }}
      </div>
    {{ end }}

    {{ if .Success }}
      <div class="form-alert form-alert-success">
        <i class="fa-solid fa-circle-check" style="margin-right: 0.5rem;"></i> {{ .Success }}
      </div>
    {{ end }}

    <form action="/login" method="POST">
      <div class="form-group">
        <label for="email" class="form-label">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="name@example.com" required>
      </div>

      <div class="form-group" style="margin-bottom: 2rem;">
        <label for="password" class="form-label">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 0.75rem;">
        <i class="fa-solid fa-right-to-bracket"></i> Login
      </button>
    </form>

    <div style="text-align: center; margin-top: 2rem; color: var(--text-secondary); font-size: 0.95rem;">
      Don't have an account? <a href="/register" style="color: var(--accent-primary); font-weight: 600;">Register here</a>
    </div>
  </div>
</section>

{{ template "layouts/footer.tmpl" . }}
{{ end }}
