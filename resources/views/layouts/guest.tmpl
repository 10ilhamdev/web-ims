        chat_support_email: "Your Email",
        chat_support_start: "Start Live Chat"
      }
    };

    // Merge database translations if they exist
    const idEl = document.getElementById('cms-translations-id');
    const enEl = document.getElementById('cms-translations-en');
    if (idEl && idEl.textContent) {
      try {
        const dbTranslationsID = JSON.parse(idEl.textContent);
        if (Object.keys(dbTranslationsID).length > 0) {
          // Clear keys not present in database
          for (const key in translations.id) {
            if (!(key in dbTranslationsID)) {
              translations.id[key] = "";
            }
          }
          Object.assign(translations.id, dbTranslationsID);
        }
      } catch(e){}
    }
    if (enEl && enEl.textContent) {
      try {
        const dbTranslationsEN = JSON.parse(enEl.textContent);
        if (Object.keys(dbTranslationsEN).length > 0) {
          // Clear keys not present in database
          for (const key in translations.en) {
            if (!(key in dbTranslationsEN)) {
              translations.en[key] = "";
            }
          }
          Object.assign(translations.en, dbTranslationsEN);
        }
      } catch(e){}
    }

    // Theme Switching (Dark -> Light -> Sunset)
    const sunIcons = document.querySelectorAll('#sun-icon');
    const moonIcons = document.querySelectorAll('#moon-icon');
    const sunsetIcons = document.querySelectorAll('#sunset-icon');

    function toggleTheme() {
      let currentTheme = 'dark';
      if (document.documentElement.classList.contains('light-theme')) {
        currentTheme = 'light';
      } else if (document.documentElement.classList.contains('sunset-theme')) {
        currentTheme = 'sunset';
      }

      document.documentElement.classList.remove('light-theme', 'sunset-theme');

      let nextTheme = 'dark';
      if (currentTheme === 'dark') {
        nextTheme = 'light';
        document.documentElement.classList.add('light-theme');
      } else if (currentTheme === 'light') {
        nextTheme = 'sunset';
        document.documentElement.classList.add('sunset-theme');
      } else {
        nextTheme = 'dark';
      }

      localStorage.setItem('theme', nextTheme);
      updateThemeIcons();
    }

    function updateThemeIcons() {
      let theme = 'dark';
      if (document.documentElement.classList.contains('light-theme')) {
        theme = 'light';
      } else if (document.documentElement.classList.contains('sunset-theme')) {
        theme = 'sunset';
      }

      const sunIcons = document.querySelectorAll('#sun-icon');
      const moonIcons = document.querySelectorAll('#moon-icon');
      const sunsetIcons = document.querySelectorAll('#sunset-icon');

      sunIcons.forEach(el => el.style.display = 'none');
      moonIcons.forEach(el => el.style.display = 'none');
      sunsetIcons.forEach(el => el.style.display = 'none');

      if (theme === 'light') {
        sunIcons.forEach(el => el.style.display = 'inline-block');
      } else if (theme === 'sunset') {
        sunsetIcons.forEach(el => el.style.display = 'inline-block');
      } else {
        moonIcons.forEach(el => el.style.display = 'inline-block');
      }
    }

    // Language Switching
    const langSelect = document.getElementById('lang-select');
    
    function changeLanguage(lang) {
      localStorage.setItem('lang', lang);
      applyTranslations(lang);
      if (langSelect) langSelect.value = lang;
    }
    window.changeLanguage = changeLanguage;

    function applyTranslations(lang) {
      const dict = translations[lang] || translations['en'];
      
      // Translate standard data-translate elements
      document.querySelectorAll('[data-translate]').forEach(el => {
        const key = el.getAttribute('data-translate');
        if (dict[key]) {
          if (key === 'hi_user') {
            const username = el.getAttribute('data-username') || '';
            el.innerHTML = '<i class="fa-solid fa-user"></i> ' + dict[key] + username;
          } else if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            el.setAttribute('placeholder', dict[key]);
          } else {
            el.textContent = dict[key];
          }
        }
      });

      // Translate dynamic value elements (e.g. features list)
      document.querySelectorAll('[data-translate-val]').forEach(el => {
        const text = el.getAttribute('data-translate-val').trim();
        const key = Object.keys(translations.id).find(k => translations.id[k] === text);
        if (key && dict[key]) {
          el.textContent = dict[key];
        } else {
          el.textContent = text;
        }
      });
    }

    // Boot theme & translation logic
    document.addEventListener("DOMContentLoaded", () => {
      // Sync Theme state
      updateThemeIcons();

      // Sync Lang state
      const savedLang = localStorage.getItem('lang') || 'en';
      window.changeLanguage(savedLang);

      // Scroll Reveal Observer
      const scrollObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          } else {
            entry.target.classList.remove('active');
          }
        });
      }, { threshold: 0.05 });

      document.querySelectorAll('.reveal').forEach(el => {
        scrollObserver.observe(el);
      });
    });
  </script>

