{{ define "layouts/guest_header" }}
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IMS - Turning Ideas Into Digital Solutions</title>
  <link rel="icon" type="image/png" href="/public/img/logo_ims.png?v=2">
  <link rel="stylesheet" href="/public/css/style.css?v=101">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script>
    // Initialize Theme immediately to prevent flash
    const savedTheme = localStorage.getItem('theme') || 'dark';
    if (savedTheme === 'light') {
      document.documentElement.classList.add('light-theme');
    } else if (savedTheme === 'sunset') {
      document.documentElement.classList.add('sunset-theme');
    }

    // Dynamic Navigation Active Link Highlight
    document.addEventListener("DOMContentLoaded", () => {
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll(".nav-links .nav-link");
      navLinks.forEach(link => {
        const href = link.getAttribute("href");
        if (href === currentPath) {
          link.classList.add("active");
        } else if (currentPath.startsWith(href) && href !== "/") {
          link.classList.add("active");
        }
      });
    });
  </script>
</head>

<body>
  <!-- Futuristic Dynamic Dot Matrix Wave Background -->
  <div class="futuristic-dot-grid"></div>

  <!-- Sunset Theme Sun Graphic -->
  <div class="sunset-sun"></div>

  <!-- Futuristic Glowing Particles Background -->
  <div class="futuristic-bubble-1"></div>
  <div class="futuristic-bubble-2"></div>
  <div class="futuristic-bubble-3"></div>
  <div class="futuristic-bubble-4"></div>

  <!-- Navbar -->
  <header class="navbar">
    <a href="/" class="logo">
      <img src="/public/img/logo_ims.png" alt="IMS Logo">
      <span>IMS</span>
    </a>

    <nav class="nav-links">
      <a href="/" class="nav-link" data-translate="nav_home">Home</a>
      <a href="/services" class="nav-link" data-translate="nav_services">Services</a>
      <a href="/products" class="nav-link" data-translate="nav_products">Products</a>

      {{ if .User }}
        {{ if eq .User.Role "admin" }}
          <a href="/admin" class="nav-link"><i class="fa-solid fa-gauge"></i> <span data-translate="nav_admin">Admin Panel</span></a>
        {{ else }}
          <a href="/orders" class="nav-link"><i class="fa-solid fa-list"></i> <span data-translate="nav_my_orders">My Orders</span></a>
        {{ end }}

        <span style="color: var(--text-muted); font-size: 0.95rem; font-weight: 500;" data-translate="hi_user"
          data-username="{{ .User.Name }}">Hi, {{ .User.Name }}</span>
        <a href="/logout" class="btn btn-secondary btn-sm"><i class="fa-solid fa-sign-out"></i> <span data-translate="nav_logout">Logout</span></a>
      {{ else }}
        <a href="/login" class="btn btn-primary btn-sm" data-translate="nav_login">Login</a>
      {{ end }}
    </nav>

    <!-- Interface Controls -->
    <div class="interface-controls">
      <button class="btn-icon" id="theme-toggle" onclick="toggleTheme()" title="Toggle Theme">
        <i class="fa-solid fa-sun" style="display:none;" id="sun-icon"></i>
        <i class="fa-solid fa-moon" style="display:none;" id="moon-icon"></i>
        <i class="fa-solid fa-mountain-sun" style="display:none;" id="sunset-icon"></i>
      </button>
      <select class="select-lang" id="lang-select" onchange="changeLanguage(this.value)" title="Change Language">
        <option value="id">ID</option>
        <option value="en">EN</option>
      </select>
    </div>
  </header>

  <main class="main-content">
{{ end }}

