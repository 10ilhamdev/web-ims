  <!-- Floating Chatbot Widget HTML -->
  <div class="chatbot-container">
    <button class="chatbot-trigger" id="chatbot-trigger" onclick="toggleChatbot()" title="Chat with us">
      <i class="fa-solid fa-comments"></i>
    </button>

    <div class="chatbot-window" id="chatbot-window">
      <div class="chatbot-header">
        <div class="chatbot-header-title">
          <i class="fa-solid fa-robot"></i>
          <span>IMS Digital Assistant</span>
        </div>
        <button class="chatbot-close-btn" onclick="toggleChatbot()">&times;</button>
      </div>

      <div class="chatbot-modes">
        <button class="chatbot-mode-btn active" id="mode-btn-ai" onclick="setChatMode('ai')" data-translate="chat_ai_assistant">AI Assistant</button>
        <button class="chatbot-mode-btn" id="mode-btn-support" onclick="setChatMode('support')" data-translate="chat_with_admin">Chat with Admin</button>
      </div>

      <!-- AI View -->
      <div class="chatbot-view" id="chatbot-view-ai">
        <div class="chatbot-messages" id="ai-messages">
          <div class="chat-bubble assistant" data-translate="chat_greeting">Hello! I am your IMS digital assistant. Select a topic or type your query below!</div>
        </div>
        <div class="chatbot-faq-list">
          <button class="chatbot-faq-btn" onclick="askFAQ('What are the packages?')" data-translate="chat_faq_packages">📦 Pricing Packages</button>
          <button class="chatbot-faq-btn" onclick="askFAQ('What services do you offer?')" data-translate="chat_faq_services">🛠️ Services</button>
          <button class="chatbot-faq-btn" onclick="askFAQ('How do I contact you?')" data-translate="chat_faq_contact">📞 Contact Info</button>
        </div>
        <div class="chatbot-input-area">
          <input type="text" id="ai-input" placeholder="Ask AI..." onkeypress="handleChatKey(event, 'ai')" data-translate="chat_placeholder_ai">
          <button onclick="sendChatMessage('ai')"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
      </div>

      <!-- Support Chat View -->
      <div class="chatbot-view" id="chatbot-view-support" style="display: none;">
        <!-- Init/Register Support Chat -->
        <div id="support-init-form" style="padding: 1.5rem 1.2rem; display: flex; flex-direction: column; gap: 0.75rem;">
          <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 0 0 0.5rem 0;" data-translate="chat_support_desc">Type your name and email to start a direct support session with our team.</p>
          <input type="text" id="support-name" placeholder="Your Name" style="background:var(--bg-primary); border:1px solid var(--border-color); border-radius:8px; padding:0.6rem 1rem; color:var(--text-primary); outline:none;" data-translate="chat_support_name">
          <input type="email" id="support-email" placeholder="Your Email" style="background:var(--bg-primary); border:1px solid var(--border-color); border-radius:8px; padding:0.6rem 1rem; color:var(--text-primary); outline:none;" data-translate="chat_support_email">
