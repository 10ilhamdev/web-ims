            <input type="text" id="support-input" placeholder="Message admin..." onkeypress="handleChatKey(event, 'support')" data-translate="chat_placeholder_admin">
            <button onclick="sendChatMessage('support')"><i class="fa-solid fa-paper-plane"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Chatbot Script -->
  <script>
    let activeMode = 'ai';
    let chatToken = localStorage.getItem('ims_chat_token');
    let supportPollingInterval = null;

    function toggleChatbot() {
      const win = document.getElementById('chatbot-window');
      win.classList.toggle('open');
      if (win.classList.contains('open')) {
        if (activeMode === 'support' && chatToken) {
          loadSupportMessages();
          startSupportPolling();
        }
      } else {
        stopSupportPolling();
      }
    }

    function setChatMode(mode) {
      activeMode = mode;
      document.getElementById('mode-btn-ai').classList.toggle('active', mode === 'ai');
      document.getElementById('mode-btn-support').classList.toggle('active', mode === 'support');
      
      document.getElementById('chatbot-view-ai').style.display = mode === 'ai' ? 'flex' : 'none';
      document.getElementById('chatbot-view-support').style.display = mode === 'support' ? 'flex' : 'none';

      if (mode === 'support') {
        if (chatToken) {
          document.getElementById('support-init-form').style.display = 'none';
          document.getElementById('support-chat-area').style.display = 'flex';
          loadSupportMessages();
          startSupportPolling();
        } else {
          document.getElementById('support-init-form').style.display = 'flex';
          document.getElementById('support-chat-area').style.display = 'none';
        }
      } else {
        stopSupportPolling();
      }
    }

    function handleChatKey(e, mode) {
      if (e.key === 'Enter') {
        sendChatMessage(mode);
      }
    }

    let currentTypingIndicator = null;

    function showTypingIndicator(containerId) {
      hideTypingIndicator();
      const container = document.getElementById(containerId);
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble assistant typing-indicator-bubble`;
      bubble.innerHTML = `
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      `;
      container.appendChild(bubble);
      container.scrollTop = container.scrollHeight;
      currentTypingIndicator = bubble;
    }

    function hideTypingIndicator() {
      if (currentTypingIndicator && currentTypingIndicator.parentNode) {
        currentTypingIndicator.parentNode.removeChild(currentTypingIndicator);
      }
      currentTypingIndicator = null;
    }

    async function sendChatMessage(mode) {
      if (mode === 'ai') {
        const input = document.getElementById('ai-input');
        const val = input.value.trim();
        if (!val) return;
        input.value = '';

        appendMessage('ai-messages', 'user', val);
        showTypingIndicator('ai-messages');

        try {
          const formData = new FormData();
          formData.append('message', val);
          formData.append('lang', localStorage.getItem('lang') || 'en');
          const res = await fetch('/api/chat/ai', {
            method: 'POST',
            body: formData
          });
          const data = await res.json();
          hideTypingIndicator();
          appendMessage('ai-messages', 'assistant', data.reply);
        } catch (err) {
          console.error("AI chat error:", err);
          hideTypingIndicator();
          appendMessage('ai-messages', 'assistant', "Sorry, I encountered an error. Please try again or chat with our admin!");
        }
      } else if (mode === 'support') {
        const input = document.getElementById('support-input');
        const val = input.value.trim();
        if (!val || !chatToken) return;
        input.value = '';

        appendMessage('support-messages', 'user', val);

        try {
          const formData = new FormData();
          formData.append('token', chatToken);
          formData.append('message', val);
          await fetch('/api/chat/support/send', {
            method: 'POST',
            body: formData
          });
          loadSupportMessages();
        } catch (err) {
          console.error("Send support message error:", err);
        }
      }
    }

    function appendMessage(containerId, sender, text) {
      const container = document.getElementById(containerId);
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble ${sender}`;
      bubble.textContent = text;
      container.appendChild(bubble);
      container.scrollTop = container.scrollHeight;
    }

    async function askFAQ(question) {
      appendMessage('ai-messages', 'user', question);
      showTypingIndicator('ai-messages');
      try {
        const formData = new FormData();
        formData.append('message', question);
        formData.append('lang', localStorage.getItem('lang') || 'en');
        const res = await fetch('/api/chat/ai', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        hideTypingIndicator();
        appendMessage('ai-messages', 'assistant', data.reply);
      } catch (err) {
        hideTypingIndicator();
        appendMessage('ai-messages', 'assistant', "Could not contact AI agent.");
      }
    }

    async function initSupportSession() {
      const name = document.getElementById('support-name').value.trim();
      const email = document.getElementById('support-email').value.trim();
      if (!name || !email) {
        alert("Name and Email are required!");
        return;
      }

      try {
        const formData = new FormData();
        formData.append('name', name);
        formData.append('email', email);
        const res = await fetch('/api/chat/support/init', {
          method: 'POST',
          body: formData
        });
        if (res.ok) {
          const data = await res.json();
          chatToken = data.token;
          localStorage.setItem('ims_chat_token', chatToken);
          
          document.getElementById('support-init-form').style.display = 'none';
          document.getElementById('support-chat-area').style.display = 'flex';
          loadSupportMessages();
          startSupportPolling();
        } else {
          alert("Failed to initialize support chat. Please try again.");
        }
      } catch (err) {
        console.error(err);
      }
    }

    async function loadSupportMessages() {
      if (!chatToken) return;
      try {
        const res = await fetch(`/api/chat/support/messages?token=${chatToken}`);
        if (!res.ok) return;
        const messages = await res.json();
        const container = document.getElementById('support-messages');
        
        const wasAtBottom = container.scrollHeight - container.clientHeight <= container.scrollTop + 20;

        let html = '';
        messages.forEach(m => {
          const sender = m.sender_type === 'admin' ? 'assistant' : 'user';
          html += `<div class="chat-bubble ${sender}">${escapeHTML(m.message)}</div>`;
        });
        container.innerHTML = html;

        if (wasAtBottom || container.scrollTop === 0) {
          container.scrollTop = container.scrollHeight;
        }
      } catch (err) {
        console.error(err);
      }
    }

    function startSupportPolling() {
      if (supportPollingInterval) clearInterval(supportPollingInterval);
      supportPollingInterval = setInterval(loadSupportMessages, 4000);
    }

    function stopSupportPolling() {
      if (supportPollingInterval) {
        clearInterval(supportPollingInterval);
        supportPollingInterval = null;
      }
    }

    function escapeHTML(str) {
      if (!str) return '';
      return str.replace(/[&<>'"]/g, 
        tag => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          "'": '&#39;',
          '"': '&quot;'
        }[tag] || tag)
      );
    }
  </script>
</body>

