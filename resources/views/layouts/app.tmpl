<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel | IMS Control Panel</title>
  <link rel="icon" type="image/png" href="/public/img/logo_ims.png?v=2">
  <link rel="stylesheet" href="/public/css/style.css?v=101">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- DataTables CSS (Included only in admin panel) -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.5/css/jquery.dataTables.min.css">
  <style>
    /* Spacing fixes for DataTables filters */
    .dataTables_wrapper {
      color: var(--text-primary) !important;
      font-family: inherit;
    }
    table.dataTable {
      border-collapse: collapse !important;
      background: var(--bg-secondary) !important;
      border-radius: 12px;
      overflow: hidden;
      margin-top: 1.5rem !important;
      margin-bottom: 1.5rem !important;
      border: 1px solid var(--border-color) !important;
    }
    table.dataTable thead th {
      background: rgba(255, 255, 255, 0.02) !important;
      color: var(--text-primary) !important;
      font-weight: 600 !important;
      padding: 1.25rem 1rem !important;
      border-bottom: 2px solid var(--border-color) !important;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }
    table.dataTable tbody td {
      padding: 1.25rem 1rem !important;
      background: none !important;
      border-bottom: 1px solid var(--border-color) !important;
      color: var(--text-primary) !important;
    }
    .dataTables_filter input {
      background: var(--bg-primary) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: 8px !important;
      padding: 0.6rem 1rem !important;
      color: var(--text-primary) !important;
      margin-left: 0.5rem !important;
    }
    .dataTables_length select {
      background: var(--bg-primary) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: 8px !important;
      padding: 0.5rem 1.5rem !important;
      color: var(--text-primary) !important;
    }
    .dataTables_length, .dataTables_filter {
      margin-bottom: 1.75rem !important;
    }
    .dataTables_info {
      color: var(--text-secondary) !important;
      font-size: 0.9rem;
    }
    .dataTables_paginate .paginate_button {
      background: var(--bg-primary) !important;
      color: var(--text-primary) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: 8px !important;
      padding: 0.5rem 1rem !important;
      margin: 0 0.25rem;
      transition: all 0.2s ease;
    }
    .dataTables_paginate .paginate_button.current, .dataTables_paginate .paginate_button.current:hover {
      background: var(--accent-primary) !important;
      color: #fff !important;
      border-color: var(--accent-primary) !important;
    }
    .dataTables_paginate .paginate_button:hover {
      background: rgba(37, 99, 235, 0.08) !important;
      color: var(--text-primary) !important;
    }
    .light-theme table.dataTable thead th {
      background: var(--bg-tertiary) !important;
    }
  </style>
</head>
<body style="background-image: none; background-color: var(--bg-primary);">
  <!-- Sunset Theme Sun Graphic -->
  <div class="sunset-sun"></div>

  <div class="admin-layout">
    
    <!-- Sidebar -->
    <aside class="admin-sidebar" style="background: var(--bg-secondary); border-right: 1px solid var(--border-color); width: 280px; transition: var(--transition-smooth); display: flex; flex-direction: column;">
      <button class="sidebar-collapse-btn" onclick="toggleSidebar()" title="Collapse Sidebar">
        <i class="fa-solid fa-chevron-left" id="collapse-icon"></i>
      </button>
      
      <div style="padding: 2rem; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; gap: 1rem;">
        <div style="width: 45px; height: 45px; border-radius: 12px; background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem; color: #fff; box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);">
          {{ if .User }}
            {{ printf "%.1s" .User.Name }}
          {{ else }}
            A
          {{ end }}
        </div>
        <div>
          <div style="font-weight: 600; font-size: 0.95rem;">{{ if .User }}{{ .User.Name }}{{ else }}Admin{{ end }}</div>
          <div style="color: var(--accent-secondary); font-size: 0.8rem; font-weight: 500; text-transform: uppercase;">{{ if .User }}{{ .User.Role }}{{ else }}User{{ end }}</div>
        </div>
      </div>
      
      <ul class="sidebar-menu">
        {{ if eq .User.Role "admin" }}
          <li>
            <a href="/admin"><i class="fa-solid fa-gauge"></i> <span data-translate="menu_dashboard">Dashboard</span></a>
          </li>
          
          <li>
            <a href="/admin/cms"><i class="fa-solid fa-file-pen"></i> <span data-translate="menu_cms">CMS Pages</span></a>
          </li>
          
          <li>
            <a href="/admin/chat"><i class="fa-solid fa-comments"></i> <span data-translate="menu_support_chat">Support Chat</span></a>
          </li>
          
        <li class="has-submenu">
            <a href="javascript:void(0)" onclick="toggleSubmenu(this)">
              <i class="fa-solid fa-users-gear"></i> <span data-translate="menu_users_roles">User & Roles</span>
              <i class="fa-solid fa-chevron-down submenu-arrow"></i>
            </a>
            <ul class="sidebar-submenu" style="display: none;">
              <li>
                <a href="/admin/users"><i class="fa-solid fa-user-shield"></i> <span data-translate="menu_users">User Management</span></a>
              </li>
              <li>
                <a href="/admin/roles"><i class="fa-solid fa-database"></i> <span data-translate="menu_roles">Role & DB Manager</span></a>
              </li>
            </ul>
        </li>
        {{ else }}
          <li>
            <a href="/orders"><i class="fa-solid fa-list-check"></i> <span data-translate="menu_orders">My Project Orders</span></a>
          </li>
        {{ end }}
        <li>
          <a href="/"><i class="fa-solid fa-globe"></i> <span data-translate="menu_website">Main Website</span></a>
        </li>
        <li>
          <a href="/products"><i class="fa-solid fa-list-check"></i> <span data-translate="menu_packages">Pricing Packages</span></a>
        </li>
        <li style="margin-top: 3rem;">
          <a href="/logout" class="btn btn-danger btn-sm" style="color: #fff; justify-content: center; gap: 0.5rem;">
            <i class="fa-solid fa-sign-out"></i> <span>Logout</span>
          </a>
        </li>
      </ul>
    </aside>

    <!-- Main Admin Content -->
    <main class="admin-content" style="flex: 1; padding: 2.5rem; overflow-y: auto;">
      
      <!-- Top Navbar -->
      <div class="admin-navbar" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 2rem; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); font-family: inherit; position: relative; z-index: 1000;">
        <div style="font-weight: 700; font-family: var(--font-mono); color: var(--accent-secondary); font-size: 1.1rem; display: flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-cube"></i> <span data-translate="control_panel">IMS CONTROL PANEL</span>
        </div>
        
        <div style="display: flex; align-items: center; gap: 1.5rem;">
          <!-- Interface Controls -->
          <div class="interface-controls" style="display: flex; align-items: center; gap: 0.75rem;">
            <button class="btn-icon" id="admin-theme-toggle" onclick="toggleTheme()" title="Toggle Theme" style="border: 1px solid var(--border-color); border-radius: 8px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-primary); transition: var(--transition-smooth);">
              <i class="fa-solid fa-sun" style="display:none;" id="sun-icon"></i>
              <i class="fa-solid fa-moon" style="display:none;" id="moon-icon"></i>
              <i class="fa-solid fa-mountain-sun" style="display:none;" id="sunset-icon"></i>
            </button>
            <select class="select-lang" id="lang-select" onchange="changeLanguage(this.value)" title="Change Language" style="background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.5rem 1rem; color: var(--text-primary); font-family: inherit; font-size: 0.9rem; cursor: pointer; outline: none; transition: var(--transition-smooth);">
              <option value="id">ID</option>
              <option value="en">EN</option>
            </select>
          </div>

          <!-- User Profile Dropdown -->
          <div class="user-dropdown-container" style="position: relative; display: inline-block;">
            <button class="user-dropdown-trigger" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); cursor: pointer; display: flex; align-items: center; gap: 0.75rem; color: var(--text-primary); padding: 0.5rem 1rem; border-radius: 10px; transition: var(--transition-smooth);" onclick="toggleAdminUserDropdown(event)">
              <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem;">
                {{ if .User }}{{ printf "%.1s" .User.Name }}{{ else }}A{{ end }}
              </div>
              <span style="font-size: 0.9rem; font-weight: 600;">{{ if .User }}{{ .User.Name }}{{ else }}Admin{{ end }}</span>
              <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem; opacity: 0.7;"></i>
            </button>

            <div class="user-dropdown-menu" id="adminUserDropdownMenu" style="display: none; position: absolute; right: 0; top: 120%; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; min-width: 240px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); z-index: 1000; padding: 0.5rem 0; overflow: hidden; animation: dropdownFadeIn 0.2s ease;">
              <div style="padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-color); margin-bottom: 0.25rem;">
                <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;">{{ if .User }}{{ .User.Name }}{{ else }}Admin{{ end }}</div>
                <div style="font-size: 0.75rem; color: var(--text-secondary);">{{ if .User }}{{ .User.Email }}{{ else }}admin@ims.com{{ end }}</div>
              </div>
              <a href="/profile" class="dropdown-item">
                <i class="fa-solid fa-id-card" style="width: 16px; color: var(--accent-primary);"></i> <span data-translate="menu_profile">Data Profil</span>
              </a>
              <a href="/profile/password" class="dropdown-item">
                <i class="fa-solid fa-key" style="width: 16px; color: var(--accent-secondary);"></i> <span data-translate="menu_password">Password</span>
              </a>
              <a href="/profile/activity" class="dropdown-item">
                <i class="fa-solid fa-clock-rotate-left" style="width: 16px; color: #10b981;"></i> <span data-translate="menu_activity">Riwayat Aktivitas</span>
              </a>
              <a href="/logout" class="dropdown-item logout-item">
                <i class="fa-solid fa-sign-out" style="width: 16px;"></i> <span data-translate="menu_logout">Keluar (Logout)</span>
              </a>
            </div>
          </div>
        </div>
      </div>
{{ end }}

{{ define "layouts/app_footer" }}
    </main>
  </div>

