    function toggleAdminUserDropdown(event) {
      event.stopPropagation();
      const menu = document.getElementById('adminUserDropdownMenu');
      if (menu) {
        const isVisible = menu.style.display === 'block';
        menu.style.display = isVisible ? 'none' : 'block';
      }
    }

    // Close dropdown on click outside
    document.addEventListener('click', () => {
      const menu = document.getElementById('adminUserDropdownMenu');
      if (menu) menu.style.display = 'none';
    });

    // Theme Switching (Dark -> Light -> Sunset)
    const sunIcons = document.querySelectorAll('#sun-icon');
    const moonIcons = document.querySelectorAll('#moon-icon');
    const sunsetIcons = document.querySelectorAll('#sunset-icon');

    function toggleTheme() {
      let currentTheme = 'dark';
      if (document.documentElement.classList.contains('light-theme')) {
        currentTheme = 'light';
      } else if (document.documentElement.classList.contains('sunset-theme')) {
        currentTheme = 'sunset';
      }

      document.documentElement.classList.remove('light-theme', 'sunset-theme');

      let nextTheme = 'dark';
      if (currentTheme === 'dark') {
        nextTheme = 'light';
        document.documentElement.classList.add('light-theme');
      } else if (currentTheme === 'light') {
        nextTheme = 'sunset';
        document.documentElement.classList.add('sunset-theme');
      } else {
        nextTheme = 'dark';
      }

      localStorage.setItem('theme', nextTheme);
      updateThemeIcons();
    }

    function updateThemeIcons() {
      let theme = 'dark';
      if (document.documentElement.classList.contains('light-theme')) {
        theme = 'light';
      } else if (document.documentElement.classList.contains('sunset-theme')) {
        theme = 'sunset';
      }

      const sunIcons = document.querySelectorAll('#sun-icon');
      const moonIcons = document.querySelectorAll('#moon-icon');
      const sunsetIcons = document.querySelectorAll('#sunset-icon');

      sunIcons.forEach(el => el.style.display = 'none');
      moonIcons.forEach(el => el.style.display = 'none');
      sunsetIcons.forEach(el => el.style.display = 'none');

      if (theme === 'light') {
        sunIcons.forEach(el => el.style.display = 'inline-block');
      } else if (theme === 'sunset') {
        sunsetIcons.forEach(el => el.style.display = 'inline-block');
      } else {
        moonIcons.forEach(el => el.style.display = 'inline-block');
      }
    }

    // Translation Function
    function changeLanguage(lang) {
      const prevLang = localStorage.getItem('lang');
      localStorage.setItem('lang', lang);
      const select = document.getElementById('lang-select');
      if (select) select.value = lang;
      applyAdminTranslations(lang);
      if (prevLang && prevLang !== lang) {
        window.location.reload();
      }
    }

    function applyAdminTranslations(lang) {
      const dict = adminTranslations[lang] || adminTranslations['en'];
      document.querySelectorAll('[data-translate]').forEach(el => {
        const key = el.getAttribute('data-translate');
        if (dict[key]) {
          if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            el.setAttribute('placeholder', dict[key]);
          } else {
            el.textContent = dict[key];
          }
        }
      });
    }

    // Sidebar Collapse Toggle
    function toggleSidebar() {
      const layout = document.querySelector('.admin-layout');
      const icon = document.getElementById('collapse-icon');
      if (!layout) return;
      
      const isCollapsed = layout.classList.toggle('sidebar-collapsed');
      localStorage.setItem('sidebar-collapsed', isCollapsed ? 'true' : 'false');
      
      if (icon) {
        if (isCollapsed) {
          icon.className = 'fa-solid fa-chevron-right';
        } else {
          icon.className = 'fa-solid fa-chevron-left';
        }
      }
    }

    // Sidebar Submenu Toggle
    function toggleSubmenu(el) {
      const parent = el.closest('.has-submenu');
      if (!parent) return;
      
      const submenu = parent.querySelector('.sidebar-submenu');
      if (!submenu) return;
      
      const isOpen = parent.classList.toggle('open');
      if (isOpen) {
        submenu.style.display = 'flex';
      } else {
        submenu.style.display = 'none';
      }
    }

    // Scroll Reveal Observer
    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        } else {
          entry.target.classList.remove('visible');
        }
      });
    }, { threshold: 0.05 });

    // Initialize state on load
    document.addEventListener('DOMContentLoaded', () => {
      // Theme setup
      const currentTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.remove('light-theme', 'sunset-theme');
      if (currentTheme === 'light') {
        document.documentElement.classList.add('light-theme');
      } else if (currentTheme === 'sunset') {
        document.documentElement.classList.add('sunset-theme');
      }
      updateThemeIcons();

      // Language setup
      const currentLang = localStorage.getItem('lang') || 'en';
      changeLanguage(currentLang);

      // Sidebar state restore
      const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      const layout = document.querySelector('.admin-layout');
      const icon = document.getElementById('collapse-icon');
      if (isCollapsed && layout) {
        layout.classList.add('sidebar-collapsed');
        if (icon) icon.className = 'fa-solid fa-chevron-right';
      }

      // Dynamic Sidebar Active Link Highlight
      const currentPath = window.location.pathname;
      const sidebarLinks = document.querySelectorAll(".sidebar-menu a");
      sidebarLinks.forEach(link => {
        const href = link.getAttribute("href");
        if (href === currentPath) {
          link.closest('li').classList.add("active");
          const submenu = link.closest('.sidebar-submenu');
          if (submenu) {
            submenu.style.display = 'flex';
            const parentHasSubmenu = submenu.closest('.has-submenu');
            if (parentHasSubmenu) {
              parentHasSubmenu.classList.add('open');
            }
          }
        }
      });

      // Bind scroll reveal to components
      document.querySelectorAll('.card, .stats-grid, table, form, h1, p, .admin-navbar, .profile-card').forEach(el => {
        el.classList.add('scroll-reveal');
        scrollObserver.observe(el);
      });
    });
  </script>
</body>
</html>
{{ end }}
