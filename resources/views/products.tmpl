{{ define "products.tmpl" }}
{{ template "layouts/guest_header" . }}

<style>
.discount-pill {
  background: linear-gradient(135deg, #ff2a5f 0%, #ff7e40 100%);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 900;
  padding: 0.25rem 0.55rem;
  border-radius: 4px;
  letter-spacing: 0.05em;
  box-shadow: 0 4px 10px rgba(255, 42, 95, 0.35);
  animation: discount-pulse 2s infinite alternate;
  display: inline-block;
}
@keyframes discount-pulse {
  0% {
    transform: scale(1);
    filter: brightness(1);
  }
  100% {
    transform: scale(1.08);
    filter: brightness(1.15);
    box-shadow: 0 6px 15px rgba(255, 42, 95, 0.55);
  }
}
</style>

<section class="container animated" style="padding-top: 4rem; padding-bottom: 6rem;">
  <div class="section-header reveal reveal-up">
    <p class="hero-slogan" data-translate="products_slogan">Packages & Pricing</p>
    <h2 data-translate="products_title">Choose Your Development Package</h2>
    <p data-translate="products_desc">Honest, transparent pricing. Pick a package that aligns with your matches, and
      we'll build it with perfection.</p>
  </div>

  <div class="products-grid">
    {{ range .Products }}
    <div class="product-card {{ if eq .ID 2 }}popular{{ end }}">
      {{ if eq .ID 2 }}
      <span class="badge-popular">POPULAR</span>
      {{ end }}
      <h3 class="product-name" data-translate="product_name_{{ .ID }}">{{ .Name }}</h3>

      <div class="product-price-box" style="align-items: center; flex-wrap: wrap; gap: 0.75rem; min-height: 4rem; margin: 1.5rem 0;">
        {{ if gt .Price 0.0 }}
          <div style="display: flex; align-items: baseline;">
            <span class="product-currency" data-translate-currency>Rp</span>
            <span class="product-price price-format" data-price="{{ printf "%.0f" .Price }}">{{ printf "%.0f" .Price }}</span>
          </div>
            {{ if gt .OriginalPrice 0.0 }}
              <span class="original-price" data-original-price="{{ printf "%.0f" .OriginalPrice }}" style="text-decoration: line-through; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">Rp {{ printf "%.0f" .OriginalPrice }}</span>
              <span class="discount-pill" data-original-price="{{ printf "%.0f" .OriginalPrice }}" data-current-price="{{ printf "%.0f" .Price }}"></span>
            {{ end }}
        {{ else }}
          <span class="product-price" style="font-size: 1.8rem; font-family: inherit;" data-translate="product_price_negotiable">Hubungi Kami</span>
        {{ end }}
      </div>

      <p class="product-description" data-translate="product_desc_{{ .ID }}">{{ .Description }}</p>

      <div class="product-features-title" data-translate="products_whats_included">What's Included</div>
      <ul class="product-features-list">
        {{ range .FeaturesList }}
        <li>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="10" r="10" fill="#2563eb" fill-opacity="0.15" />
            <path d="M6 10L9 13L14 7" stroke="#2563eb" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
          <span data-translate-val="{{ . }}">{{ . }}</span>
        </li>
        {{ end }}
      </ul>

      <a href="/checkout/{{ .ID }}" class="btn btn-primary" style="justify-content: center; width: 100%;">
        {{ if gt .Price 0.0 }}
          <i class="fa-solid fa-shopping-cart"></i> <span data-translate="product_btn_{{ .ID }}">Order Now</span>
        {{ else }}
          <i class="fa-solid fa-comments"></i> <span data-translate="product_btn_{{ .ID }}">Hubungi Kami</span>
        {{ end }}
      </a>
    </div>
    {{ end }}
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    function updatePrices() {
      const lang = localStorage.getItem('lang') || 'en';
      
      // Update main prices
      document.querySelectorAll('.price-format').forEach(el => {
        const val = parseFloat(el.getAttribute('data-price'));
        if (!isNaN(val)) {
          if (lang === 'en') {
            let usd = Math.round(val / 15000);
            el.textContent = new Intl.NumberFormat('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(usd);
          } else {
            el.textContent = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(val);
          }
        }
      });

      // Update currency indicators
      document.querySelectorAll('[data-translate-currency]').forEach(el => {
        el.textContent = lang === 'en' ? '$' : 'Rp';
      });

      // Update original line-through prices
      document.querySelectorAll('.original-price').forEach(el => {
        const val = parseFloat(el.getAttribute('data-original-price'));
        if (!isNaN(val)) {
          if (lang === 'en') {
            let usd = Math.round(val / 15000);
            el.textContent = '$' + new Intl.NumberFormat('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(usd);
          } else {
            el.textContent = 'Rp ' + new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(val);
          }
        }
      });

      // Update discount pills dynamically
      document.querySelectorAll('.discount-pill').forEach(el => {
        const orig = parseFloat(el.getAttribute('data-original-price'));
        const curr = parseFloat(el.getAttribute('data-current-price'));
        if (!isNaN(orig) && !isNaN(curr) && orig > 0) {
          const pct = Math.round((1 - (curr / orig)) * 100);
          if (lang === 'en') {
            el.textContent = 'SAVE ' + pct + '%';
          } else {
            el.textContent = 'HEMAT ' + pct + '%';
          }
        }
      });
    }

    updatePrices();

    // Listen for language change to update prices
    const oldChangeLanguage = window.changeLanguage;
    window.changeLanguage = function(lang) {
      if (typeof oldChangeLanguage === 'function') {
        oldChangeLanguage(lang);
      }
      updatePrices();
    };

    // Dynamically assign reveal classes to product cards based on index
    document.querySelectorAll('.product-card').forEach((card, index) => {
      card.classList.add('reveal');
      if (index % 3 === 0) {
        card.classList.add('reveal-left');
      } else if (index % 3 === 1) {
        card.classList.add('reveal-up');
      } else {
        card.classList.add('reveal-right');
      }
    });
  });
</script>

{{ template "layouts/guest_footer" . }}
{{ end }}