{{ define "products.tmpl" }}
{{ template "layouts/header.tmpl" . }}

<section class="container animated" style="padding-top: 4rem; padding-bottom: 6rem;">
  <div class="section-header">
    <p class="hero-slogan">Packages & Pricing</p>
    <h2>Choose Your Development Package</h2>
    <p>Honest, transparent pricing. Pick a package that aligns with your current scale, and we'll build it with perfection.</p>
  </div>

  <div class="products-grid">
    {{ range .Products }}
      <div class="product-card">
        <h3 class="product-name">{{ .Name }}</h3>
        
        <div class="product-price-box">
          <span class="product-currency">Rp</span>
          <span class="product-price price-format" data-price="{{ .Price }}">{{ .Price }}</span>
        </div>
        
        <p class="product-description">{{ .Description }}</p>
        
        <div class="product-features-title">What's Included</div>
        <ul class="product-features-list">
          {{ range .FeaturesList }}
            <li>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="10" fill="#10B981" fill-opacity="0.15"/>
                <path d="M6 10L9 13L14 7" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{{ . }}</span>
            </li>
          {{ end }}
        </ul>
        
        <a href="/checkout/{{ .ID }}" class="btn btn-primary" style="justify-content: center; width: 100%;">
          <i class="fa-solid fa-shopping-cart"></i> Order Now
        </a>
      </div>
    {{ end }}
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Format prices nicely in IDR currency
    document.querySelectorAll('.price-format').forEach(el => {
      const val = parseFloat(el.getAttribute('data-price'));
      if (!isNaN(val)) {
        // Format to IDR without fraction digits
        el.textContent = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(val);
      }
    });
  });
</script>

{{ template "layouts/footer.tmpl" . }}
{{ end }}
